<Page x:Class="AnalictY.Manager.Views.UsersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F3F5F7"
      FontFamily="Segoe UI">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Width="40" Height="40" Margin="0,0,16,0" Background="Transparent" BorderThickness="0" Click="BackButton_Click">
                        <Path Data="M19 12H5M12 19l-7-7 7-7" Stroke="#6B7280" StrokeThickness="2" Fill="Transparent" Width="20" Height="20" Stretch="Uniform"/>
                    </Button>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Usuarios" FontSize="28" FontWeight="Bold" Foreground="#111827"/>
                        <TextBlock Text="Contas, perfis e permissoes do AnalictY Server" FontSize="14" Foreground="#6B7280" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="Carregar" Command="{Binding LoadCommand}" Background="#DC2626" Foreground="White" BorderThickness="0" Padding="18,9"/>
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Total" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding TotalUsers}" Foreground="#111827" FontSize="28" FontWeight="Bold" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="18">
                        <StackPanel>
                            <TextBlock Text="{Binding StatusMessage}" Foreground="#475569"/>
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" TextWrapping="Wrap" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="14">
                    <DataGrid ItemsSource="{Binding Users}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal" MinHeight="430">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                            <DataGridTextColumn Header="Usuario" Binding="{Binding Username}" Width="1*"/>
                            <DataGridTextColumn Header="E-mail" Binding="{Binding Email}" Width="1.6*"/>
                            <DataGridTextColumn Header="Perfil" Binding="{Binding Role}" Width="0.8*"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="0.8*"/>
                            <DataGridTextColumn Header="MFA" Binding="{Binding Mfa}" Width="0.6*"/>
                            <DataGridTextColumn Header="Criado em" Binding="{Binding CreatedAt}" Width="1.2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
