<UserControl x:Class="AnalictY.Manager.Views.TagsPage"
             x:Name="TagsRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1280"
             Background="#F3F5F7"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="WhiteCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="ReadableTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="ReadableCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="TagsGridCell" TargetType="DataGridCell">
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E5E7EB"/>
                    <Setter Property="Foreground" Value="#111827"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TagsGridRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F8FAFC"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E5E7EB"/>
                    <Setter Property="Foreground" Value="#111827"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Width="40"
                            Height="40"
                            Margin="0,0,16,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="NavigateBackButton_Click">
                        <Path Data="M6 6L18 18M18 6L6 18"
                              Stroke="#6B7280"
                              StrokeThickness="2"
                              Fill="Transparent"
                              Width="20"
                              Height="20"
                              Stretch="Uniform"/>
                    </Button>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Gestao de TAGs" Foreground="#111827" FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#64748B" FontSize="14" Margin="0,4,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Content="Atualizar"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding RefreshCommand}"/>
                </Grid>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#DC2626"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource WhiteCard}" Margin="0,0,12,0">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Top">
                                <TextBlock Text="Pastas" Foreground="#111827" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button Content="Nova" Style="{StaticResource PrimaryButton}" Command="{Binding CreateFolderCommand}" Padding="12,7" Margin="0,0,6,0"/>
                                    <Button Content="Editar" Style="{StaticResource SecondaryButton}" Command="{Binding EditFolderCommand}" Padding="12,7" Margin="0,0,6,0"/>
                                    <Button Content="Excluir" Style="{StaticResource DangerButton}" Command="{Binding DeleteFolderCommand}" Padding="12,7"/>
                                </StackPanel>
                            </StackPanel>

                            <ListBox ItemsSource="{Binding FolderFilterOptions}"
                                     SelectedItem="{Binding SelectedFolderOption, Mode=TwoWay}"
                                     x:Name="FoldersList"
                                     AllowDrop="True"
                                     DragOver="FoldersList_DragOver"
                                     Drop="FoldersList_Drop"
                                     BorderBrush="#E5E7EB"
                                     BorderThickness="1"
                                     Background="#F8FAFC"
                                     MinHeight="480">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="#111827"
                                                   FontSize="14"
                                                   Padding="8,7"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource WhiteCard}">
                        <StackPanel>
                            <StackPanel Margin="0,0,0,14">
                                <TextBlock Text="Pesquisar TAGs" Style="{StaticResource LabelText}"/>
                                <TextBox Style="{StaticResource ReadableTextBox}"
                                         Text="{Binding Search, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <DataGrid ItemsSource="{Binding FilteredTags}"
                                      x:Name="TagsDataGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      SelectedItem="{Binding SelectedTag}"
                                      PreviewMouseMove="TagsDataGrid_PreviewMouseMove"
                                      MinHeight="500"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      RowHeaderWidth="0"
                                      AlternationCount="2"
                                      RowStyle="{StaticResource TagsGridRow}"
                                      CellStyle="{StaticResource TagsGridCell}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="1.4*"/>
                                    <DataGridTextColumn Header="Pasta" Binding="{Binding FolderName}" Width="1.1*"/>
                                    <DataGridTextColumn Header="Driver" Binding="{Binding DriverType}" Width="0.7*"/>
                                    <DataGridTextColumn Header="Endereco" Binding="{Binding Address}" Width="1.8*"/>
                                    <DataGridTextColumn Header="Tipo" Binding="{Binding DataType}" Width="0.7*"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="0.8*"/>
                                    <DataGridTextColumn Header="Valor" Binding="{Binding CurrentValue}" Width="0.8*"/>
                                    <DataGridTextColumn Header="Qualidade" Binding="{Binding Quality}" Width="0.8*"/>
                                    <DataGridTextColumn Header="Scan" Binding="{Binding ScanRate}" Width="0.7*"/>
                                    <DataGridTemplateColumn Header="Acoes" Width="150">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="Editar"
                                                            Style="{StaticResource SecondaryButton}"
                                                            Padding="8,5"
                                                            Margin="0,0,6,0"
                                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Content="Excluir"
                                                            Style="{StaticResource DangerButton}"
                                                            Padding="8,5"
                                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                                <Button Content="Editar selecionada" Style="{StaticResource SecondaryButton}" Command="{Binding EditCommand}" Margin="0,0,8,0"/>
                                <Button Content="Excluir selecionada" Style="{StaticResource DangerButton}" Command="{Binding DeleteCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <Grid Background="#99000000" Visibility="{Binding TagEditorVisibility}">
            <Border Style="{StaticResource WhiteCard}" Width="520" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{Binding FormTitle}" Foreground="#111827" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

                    <TextBlock Text="Nome" Style="{StaticResource LabelText}"/>
                    <TextBox Style="{StaticResource ReadableTextBox}" Text="{Binding TagName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <TextBlock Text="Endereco / NodeId / Topico" Style="{StaticResource LabelText}"/>
                    <TextBox Style="{StaticResource ReadableTextBox}" Text="{Binding Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <TextBlock Text="Pasta" Style="{StaticResource LabelText}"/>
                    <ComboBox Style="{StaticResource ReadableCombo}"
                              ItemsSource="{Binding Folders}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding SelectedFolderId, Mode=TwoWay}"
                              Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="Tipo" Style="{StaticResource LabelText}"/>
                            <ComboBox Style="{StaticResource ReadableCombo}" ItemsSource="{Binding DataTypes}" SelectedItem="{Binding DataType, Mode=TwoWay}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="6,0,0,0">
                            <TextBlock Text="Driver" Style="{StaticResource LabelText}"/>
                            <ComboBox Style="{StaticResource ReadableCombo}" ItemsSource="{Binding DriverTypes}" SelectedItem="{Binding DriverType, Mode=TwoWay}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="OPC UA ID" Style="{StaticResource LabelText}"/>
                            <TextBox Style="{StaticResource ReadableTextBox}" Text="{Binding OpcUaConnectionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="6,0,0,0">
                            <TextBlock Text="MQTT ID" Style="{StaticResource LabelText}"/>
                            <TextBox Style="{StaticResource ReadableTextBox}" Text="{Binding MqttConnectionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Poll Interval (ms)" Style="{StaticResource LabelText}"/>
                    <TextBox Style="{StaticResource ReadableTextBox}" Text="{Binding PollIntervalMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <CheckBox Content="Ativa" IsChecked="{Binding IsActive, Mode=TwoWay}" Margin="0,0,0,18"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar" Style="{StaticResource SecondaryButton}" Command="{Binding CloseModalCommand}" Margin="0,0,8,0"/>
                        <Button Content="Salvar" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Background="#99000000" Visibility="{Binding FolderEditorVisibility}">
            <Border Style="{StaticResource WhiteCard}" Width="420" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{Binding FolderModalTitle}" Foreground="#111827" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

                    <TextBlock Text="Nome da pasta" Style="{StaticResource LabelText}"/>
                    <TextBox Style="{StaticResource ReadableTextBox}" Text="{Binding NewFolderName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <TextBlock Text="Pasta mae" Style="{StaticResource LabelText}"/>
                    <ComboBox Style="{StaticResource ReadableCombo}"
                              ItemsSource="{Binding Folders}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding NewFolderParentId, Mode=TwoWay}"
                              Margin="0,0,0,18"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar" Style="{StaticResource SecondaryButton}" Command="{Binding CloseModalCommand}" Margin="0,0,8,0"/>
                        <Button Content="Salvar" Style="{StaticResource PrimaryButton}" Command="{Binding SaveFolderCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Background="#99000000" Visibility="{Binding DeleteModalVisibility}">
            <Border Style="{StaticResource WhiteCard}" Width="420" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{Binding DeleteModalTitle}" Foreground="#111827" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <TextBlock Text="{Binding DeleteModalMessage}" Foreground="#374151" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,18"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar" Style="{StaticResource SecondaryButton}" Command="{Binding CloseModalCommand}" Margin="0,0,8,0"/>
                        <Button Content="Excluir" Style="{StaticResource DangerButton}" Command="{Binding ConfirmDeleteCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
