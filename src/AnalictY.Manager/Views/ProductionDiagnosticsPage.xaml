<UserControl x:Class="AnalictY.Manager.Views.ProductionDiagnosticsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="760" d:DesignWidth="1280"
             Background="#F3F5F7"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="WhiteCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="ReadableCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Width="40" Height="40" Margin="0,0,16,0" Background="Transparent" BorderThickness="0" Click="NavigateBackButton_Click">
                        <Path Data="M6 6L18 18M18 6L6 18" Stroke="#6B7280" StrokeThickness="2" Fill="Transparent" Width="20" Height="20" Stretch="Uniform"/>
                    </Button>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Diagnóstico de Produção" Foreground="#111827" FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#64748B" FontSize="14" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <Border x:Name="ErrorBorder" Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="8"
                        Padding="14" Margin="0,0,0,14" Visibility="Collapsed">
                    <TextBlock x:Name="ErrorText" Foreground="#DC2626" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </Border>

                <Border Style="{StaticResource WhiteCard}" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Máquina" Foreground="#1F2937" FontSize="13" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding Machines}" DisplayMemberPath="Name" SelectedValuePath="Id"
                                      SelectedValue="{Binding MachineId, Mode=TwoWay}" Style="{StaticResource ReadableCombo}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Data" Foreground="#1F2937" FontSize="13" Margin="0,0,0,6"/>
                            <DatePicker SelectedDate="{Binding SelectedDate, Mode=TwoWay}" Height="34"/>
                        </StackPanel>
                        <Button Grid.Column="2" Content="Atualizar" Style="{StaticResource PrimaryButton}" Command="{Binding LoadCommand}" Margin="12,0,0,0" VerticalAlignment="Bottom"/>
                        <Button Grid.Column="3" Content="{Binding AutoRefresh, Converter={StaticResource BoolToYesNo}, StringFormat='{}{0} Tempo Real'}"
                                Style="{StaticResource SecondaryButton}" Command="{Binding ToggleAutoRefreshCommand}" Margin="8,0,0,0" VerticalAlignment="Bottom"/>
                    </Grid>
                </Border>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource WhiteCard}" Margin="0,0,6,0">
                        <StackPanel>
                            <TextBlock Text="Máquina" Foreground="#6B7280" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Text="{Binding SelectedMachine.Name, FallbackValue='-'}" Foreground="#111827" FontSize="20" FontWeight="Bold" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding SelectedMachine.Code, FallbackValue='-'}" Foreground="#6B7280" FontSize="12"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource WhiteCard}" Margin="6,0">
                        <StackPanel>
                            <TextBlock Text="Produzidas" Foreground="#6B7280" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Totals.Produced, StringFormat='{}{0:N0}', FallbackValue='0'}" Foreground="#111827" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource WhiteCard}" Margin="6,0">
                        <StackPanel>
                            <TextBlock Text="Boas" Foreground="#6B7280" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Totals.Good, StringFormat='{}{0:N0}', FallbackValue='0'}" Foreground="#111827" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Totals.Losses, StringFormat='{}{0:N0} perdas', FallbackValue='0 perdas'}" Foreground="#6B7280" FontSize="12"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Style="{StaticResource WhiteCard}" Margin="6,0">
                        <StackPanel>
                            <TextBlock Text="Qualidade" Foreground="#6B7280" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Totals.QualityPercent, StringFormat='{}{0:N0}%', FallbackValue='0%'}" Foreground="#111827" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Style="{StaticResource WhiteCard}" Margin="6,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Fila MySQL" Foreground="#6B7280" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Snapshot.Queues[mysql_pending], FallbackValue='0'}" Foreground="#111827" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Snapshot.Queues[mysql_failed], StringFormat='{}{0} falhas', FallbackValue='0 falhas'}" Foreground="#6B7280" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Style="{StaticResource WhiteCard}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Pipeline" Foreground="#111827" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                        <DataGrid ItemsSource="{Binding Snapshot.Pipeline}" AutoGenerateColumns="True" CanUserAddRows="False" IsReadOnly="True" Height="170"/>
                    </StackPanel>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource WhiteCard}" Margin="0,0,6,0">
                        <StackPanel>
                            <TextBlock Text="TAGs da Máquina" Foreground="#111827" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            <DataGrid ItemsSource="{Binding Snapshot.Sqlite.Tags}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Height="300">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Alias" Binding="{Binding Alias}" Width="*"/>
                                    <DataGridTextColumn Header="Tag ID" Binding="{Binding TagId}" Width="*"/>
                                    <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="Valor" Binding="{Binding Value}" Width="*"/>
                                    <DataGridTextColumn Header="Qualidade" Binding="{Binding Quality}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource WhiteCard}" Margin="6,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Eventos de Produção" Foreground="#111827" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            <DataGrid ItemsSource="{Binding Snapshot.Mysql.ProductionEvents}" AutoGenerateColumns="True" CanUserAddRows="False" IsReadOnly="True" Height="300"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBlock Text="Horários exibidos no fuso configurado:" Foreground="#3B82F6" FontSize="12" Margin="0,14,0,0"/>
                <TextBlock Text="{Binding TimeZoneLabel}" Foreground="#6B7280" FontSize="12" Margin="0,2,0,0"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
