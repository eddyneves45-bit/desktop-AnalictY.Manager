<Page x:Class="AnalictY.Manager.Views.ConnectionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="760" d:DesignWidth="1280"
      Background="#F3F5F7"
      FontFamily="Segoe UI">

    <Page.Resources>
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
        </Style>

        <DataTemplate x:Key="ConnectionRowTemplate">
            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,10" Background="#F9FAFB">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" Foreground="#111827"/>
                        <TextBlock Text="{Binding Details}" FontSize="12" Foreground="#64748B" Margin="0,4,0,0"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1" Text="{Binding Address}" FontSize="14" Foreground="#334155"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                    <TextBlock Grid.Column="2" Text="{Binding Status}" FontSize="13" FontWeight="SemiBold"
                               Foreground="#059669" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="3" Orientation="Horizontal">
                        <Button Content="Testar" Padding="14,7" Margin="0,0,8,0"
                                Background="#EEF2FF" Foreground="#1E40AF" BorderBrush="#CBD5E1" Cursor="Hand"/>
                        <Button Content="Editar" Padding="14,7"
                                Background="#F8FAFC" Foreground="#334155" BorderBrush="#CBD5E1" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Button Width="40" Height="40" Margin="0,0,16,0"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Click="BackButton_Click">
                            <Path Data="M6 6L18 18M18 6L6 18"
                                  Stroke="#6B7280" StrokeThickness="2"
                                  Fill="Transparent"
                                  Width="20" Height="20" Stretch="Uniform"/>
                        </Button>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Conexoes" FontSize="28" FontWeight="Bold" Foreground="#111827"/>
                            <TextBlock Text="{Binding StatusMessage}" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1" Content="Atualizar" Command="{Binding RefreshCommand}"
                            Background="#E7252A" Foreground="White" BorderThickness="0"
                            Padding="18,10" VerticalAlignment="Center" Cursor="Hand"/>
                </Grid>

                <Border Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="10"
                        Padding="14" Margin="0,0,0,18">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#991B1B" FontWeight="SemiBold"/>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="OPC UA" FontSize="18" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,14"/>
                        <ItemsControl ItemsSource="{Binding OpcUaConnections}" ItemTemplate="{StaticResource ConnectionRowTemplate}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="MQTT" FontSize="18" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,14"/>
                        <ItemsControl ItemsSource="{Binding MqttConnections}" ItemTemplate="{StaticResource ConnectionRowTemplate}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="MySQL" FontSize="18" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,14"/>
                        <ItemsControl ItemsSource="{Binding MysqlConnections}" ItemTemplate="{StaticResource ConnectionRowTemplate}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="FTP / SFTP" FontSize="18" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,14"/>
                        <ItemsControl ItemsSource="{Binding FtpConnections}" ItemTemplate="{StaticResource ConnectionRowTemplate}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
