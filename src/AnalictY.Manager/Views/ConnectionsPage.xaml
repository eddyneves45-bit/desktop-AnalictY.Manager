<Page x:Class="AnalictY.Manager.Views.ConnectionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="760" d:DesignWidth="1280"
      Background="#F3F5F7"
      FontFamily="Segoe UI">
    
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <Grid Margin="0,0,0,24">
                    <StackPanel Orientation="Horizontal">
                        <Button Width="40" Height="40" Margin="0,0,16,0"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Click="BackButton_Click">
                            <Path Data="M19 12H5M12 19l-7-7 7-7" 
                                  Stroke="#6B7280" StrokeThickness="2" 
                                  Fill="Transparent" 
                                  Width="20" Height="20" Stretch="Uniform"/>
                        </Button>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Conexões" FontSize="28" FontWeight="Bold" Foreground="#111827"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="24" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="Conexões Salvas" FontSize="18" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,16"/>
                        
                        <!-- OPC UA Connections -->
                        <TextBlock Text="OPC UA Connections" FontSize="16" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,12"/>
                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,16" Background="#F9FAFB">
                            <TextBlock Text="Nenhuma conexão OPC UA salva." FontSize="14" Foreground="#6B7280" HorizontalAlignment="Center"/>
                        </Border>

                        <!-- MQTT Connections -->
                        <TextBlock Text="MQTT Connections" FontSize="16" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,12"/>
                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,16" Background="#F9FAFB">
                            <TextBlock Text="Nenhuma conexão MQTT salva." FontSize="14" Foreground="#6B7280" HorizontalAlignment="Center"/>
                        </Border>

                        <!-- MySQL Connections -->
                        <TextBlock Text="MySQL Connections" FontSize="16" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,12"/>
                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,16" Background="#F9FAFB">
                            <TextBlock Text="Nenhuma conexão MySQL salva." FontSize="14" Foreground="#6B7280" HorizontalAlignment="Center"/>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Content="Adicionar Conexão OPC" 
                                    Background="#10B981" Foreground="White"
                                    BorderThickness="0" Padding="16,8" Margin="0,0,8,0"
                                    Cursor="Hand"/>
                            <Button Content="Adicionar Conexão MQTT" 
                                    Background="#6366F1" Foreground="White"
                                    BorderThickness="0" Padding="16,8" Margin="0,0,8,0"
                                    Cursor="Hand"/>
                            <Button Content="Adicionar Conexão MySQL" 
                                    Background="#0EA5E9" Foreground="White"
                                    BorderThickness="0" Padding="16,8"
                                    Cursor="Hand"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
