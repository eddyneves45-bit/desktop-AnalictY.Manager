<Page x:Class="AnalictY.Manager.Views.LogsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="760" d:DesignWidth="1280"
      Background="#F3F5F7"
      FontFamily="Segoe UI">
    
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <Grid Margin="0,0,0,24">
                    <StackPanel Orientation="Horizontal">
                        <Button Width="40" Height="40" Margin="0,0,16,0"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Click="BackButton_Click">
                            <Path Data="M6 6L18 18M18 6L6 18" 
                                  Stroke="#6B7280" StrokeThickness="2" 
                                  Fill="Transparent" 
                                  Width="20" Height="20" Stretch="Uniform"/>
                        </Button>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Logs" FontSize="28" FontWeight="Bold" Foreground="#111827"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="24" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="Visualização de Logs" FontSize="18" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,16"/>
                        <TextBlock Text="Painel técnico do sistema" FontSize="14" Foreground="#6B7280" Margin="0,0,0,16"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Nível de Log:" Foreground="#374151" Margin="0,0,0,8"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                      BorderBrush="#D1D5DB" BorderThickness="1" Padding="8">
                                <ComboBoxItem Content="Todos"/>
                                <ComboBoxItem Content="Debug"/>
                                <ComboBoxItem Content="Info"/>
                                <ComboBoxItem Content="Warning"/>
                                <ComboBoxItem Content="Error"/>
                            </ComboBox>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Fonte:" Foreground="#374151" Margin="0,0,0,8"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                      BorderBrush="#D1D5DB" BorderThickness="1" Padding="8">
                                <ComboBoxItem Content="Todas as fontes"/>
                                <ComboBoxItem Content="OPC UA"/>
                                <ComboBoxItem Content="MQTT"/>
                                <ComboBoxItem Content="Database"/>
                                <ComboBoxItem Content="System"/>
                            </ComboBox>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Últimas:" Foreground="#374151" Margin="0,0,0,8"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                      BorderBrush="#D1D5DB" BorderThickness="1" Padding="8">
                                <ComboBoxItem Content="100 linhas"/>
                                <ComboBoxItem Content="500 linhas"/>
                                <ComboBoxItem Content="1000 linhas"/>
                            </ComboBox>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Content="Carregar Logs" 
                                    Background="#06B6D4" Foreground="White"
                                    BorderThickness="0" Padding="16,8" Margin="0,0,8,0"
                                    Cursor="Hand"/>
                            <Button Content="Limpar" 
                                    Background="#E5E7EB" Foreground="#374151"
                                    BorderThickness="0" Padding="16,8"
                                    Cursor="Hand"/>
                        </StackPanel>

                        <Border Background="#1E293B" CornerRadius="8" Padding="16" Margin="0,16,0,0" Height="300">
                            <TextBlock Text="Nenhum log carregado." Foreground="#94A3B8" FontFamily="Consolas" FontSize="12"/>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
