<UserControl x:Class="AnalictY.Manager.Views.OpcUaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="760" d:DesignWidth="1280"
             Background="#F3F5F7"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="WhiteCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="BlueButton" TargetType="Button">
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="ReadableCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <DataTemplate x:Key="NodeRowTemplate">
            <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,0,10" Cursor="Hand">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding HasChildren, Converter={StaticResource BoolToFolderIcon}}" FontSize="18" Foreground="#64748B" Margin="0,0,12,0"/>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding Name}" Foreground="#111827" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding NodeId}" Foreground="#64748B" FontSize="12" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <TextBlock Grid.Column="2" Text="{Binding Type}" Foreground="#64748B" FontSize="12" Margin="12,0,0,0"/>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Width="40" Height="40" Margin="0,0,16,0" Background="Transparent" BorderThickness="0" Click="NavigateBackButton_Click">
                        <Path Data="M6 6L18 18M18 6L6 18" Stroke="#6B7280" StrokeThickness="2" Fill="Transparent" Width="20" Height="20" Stretch="Uniform"/>
                    </Button>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Navegador OPC UA" Foreground="#111827" FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#64748B" FontSize="14" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <ComboBox x:Name="ConnectionComboBox" ItemsSource="{Binding Connections}" DisplayMemberPath="DisplayName" 
                                  SelectedValuePath="Id" SelectedValue="{Binding SelectedConnectionId}" 
                                  Style="{StaticResource ReadableCombo}" Width="300" Margin="0,0,12,0" SelectionChanged="ConnectionComboBox_SelectionChanged"/>
                        <Button Content="Atualizar" Style="{StaticResource BlueButton}" Command="{Binding RefreshCommand}"/>
                    </StackPanel>
                </Grid>

                <Border x:Name="ErrorBorder" Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="8"
                        Padding="14" Margin="0,0,0,14" Visibility="Collapsed">
                    <TextBlock x:Name="ErrorText" Foreground="#DC2626" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource WhiteCard}" Margin="0,0,12,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Address Space" Foreground="#64748B" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding CurrentNodeId}" Foreground="#111827" FontSize="13" FontFamily="Consolas" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="Voltar" Style="{StaticResource SecondaryButton}" Click="BackButton_Click" IsEnabled="{Binding CanGoBack}"/>
                                    <Button Content="Raiz" Style="{StaticResource PrimaryButton}" Click="RootButton_Click"/>
                                </StackPanel>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Breadcrumb}" Margin="0,0,0,14">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,0,6,6">
                                            <TextBlock Text="{Binding}" Foreground="#475569" FontSize="11" FontWeight="Medium"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Nós" Foreground="#111827" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <ItemsControl ItemsSource="{Binding Nodes}" ItemTemplate="{StaticResource NodeRowTemplate}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource WhiteCard}">
                        <StackPanel>
                            <TextBlock Text="Detalhes do Nó" Foreground="#111827" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            
                            <StackPanel x:Name="NodeDetailsPanel" Visibility="Collapsed">
                                <StackPanel.Resources>
                                    <Style TargetType="TextBlock" x:Key="LabelStyle">
                                        <Setter Property="Foreground" Value="#64748B"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="Margin" Value="0,0,0,4"/>
                                    </Style>
                                    <Style TargetType="TextBlock" x:Key="ValueStyle">
                                        <Setter Property="Foreground" Value="#111827"/>
                                        <Setter Property="FontSize" Value="14"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Margin" Value="0,0,0,16"/>
                                    </Style>
                                </StackPanel.Resources>

                                <TextBlock Text="Nome" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding SelectedNode.Name}" Style="{StaticResource ValueStyle}"/>

                                <TextBlock Text="Node Id" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding SelectedNode.NodeId}" Style="{StaticResource ValueStyle}" FontFamily="Consolas" TextTrimming="CharacterEllipsis"/>

                                <TextBlock Text="Tipo" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding SelectedNode.Type}" Style="{StaticResource ValueStyle}"/>

                                <TextBlock Text="Qualidade" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding SelectedNode.Quality}" Style="{StaticResource ValueStyle}"/>

                                <TextBlock Text="Tem Filhos" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="{Binding SelectedNode.HasChildren, Converter={StaticResource BoolToYesNo}}" Style="{StaticResource ValueStyle}"/>

                                <Button Content="Criar TAG" Style="{StaticResource PrimaryButton}" Click="CreateTag_Click" Margin="0,8,0,0"/>
                            </StackPanel>

                            <TextBlock x:Name="NoSelectionText" Text="Selecione um nó para ver os detalhes" 
                                       Foreground="#9CA3AF" FontSize="14" FontStyle="Italic" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <Grid x:Name="NotificationOverlay" Background="#66000000" Visibility="Collapsed">
            <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Padding="26"
                    Width="420" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock x:Name="NotificationTitle" Text="Aviso" Foreground="#111827" FontSize="22" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock x:Name="NotificationMessage" Foreground="#475569" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,22"/>
                    <Button Content="OK" Width="100" HorizontalAlignment="Right" Style="{StaticResource PrimaryButton}" Click="CloseNotification_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="TagModalOverlay" Background="#66000000" Visibility="Collapsed">
            <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Padding="28"
                    Width="500" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Criar TAG" Foreground="#111827" FontSize="22" FontWeight="Bold" Margin="0,0,0,18"/>
                    
                    <TextBlock Text="Nome da TAG" Foreground="#1F2937" FontSize="13" Margin="0,0,0,6"/>
                    <TextBox x:Name="TagNameTextBox" Background="White" Foreground="#111827" BorderBrush="#CBD5E1" 
                             BorderThickness="1" Padding="10,8" FontSize="14" Margin="0,0,0,14"/>

                    <TextBlock Text="Tipo de Dado" Foreground="#1F2937" FontSize="13" Margin="0,0,0,6"/>
                    <ComboBox x:Name="DataTypeComboBox" Style="{StaticResource ReadableCombo}" Margin="0,0,0,14">
                        <ComboBoxItem Content="Double"/>
                        <ComboBoxItem Content="Float"/>
                        <ComboBoxItem Content="Int32"/>
                        <ComboBoxItem Content="Int16"/>
                        <ComboBoxItem Content="Boolean"/>
                        <ComboBoxItem Content="String"/>
                    </ComboBox>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                        <Button Content="Cancelar" Style="{StaticResource SecondaryButton}" Click="CancelTag_Click"/>
                        <Button Content="Criar" Style="{StaticResource PrimaryButton}" Click="ConfirmTag_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
