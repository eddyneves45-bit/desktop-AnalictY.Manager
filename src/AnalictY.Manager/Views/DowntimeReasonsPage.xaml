<UserControl x:Class="AnalictY.Manager.Views.DowntimeReasonsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="760" d:DesignWidth="1280"
             Background="#F3F5F7"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="WhiteCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="ReadableTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Width="40" Height="40" Margin="0,0,16,0" Background="Transparent" BorderThickness="0" Click="NavigateBackButton_Click">
                        <Path Data="M6 6L18 18M18 6L6 18" Stroke="#6B7280" StrokeThickness="2" Fill="Transparent" Width="20" Height="20" Stretch="Uniform"/>
                    </Button>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Histórico de Paradas" Foreground="#111827" FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#64748B" FontSize="14" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <ComboBox SelectedItem="{Binding RetentionDays, Mode=TwoWay}" Margin="0,0,12,0" Width="120">
                            <ComboBoxItem Content="1 dia"/>
                            <ComboBoxItem Content="2 dias"/>
                            <ComboBoxItem Content="3 dias"/>
                            <ComboBoxItem Content="4 dias"/>
                            <ComboBoxItem Content="5 dias"/>
                            <ComboBoxItem Content="6 dias"/>
                            <ComboBoxItem Content="7 dias"/>
                        </ComboBox>
                        <Button Content="Atualizar" Style="{StaticResource PrimaryButton}" Command="{Binding RefreshCommand}"/>
                    </StackPanel>
                </Grid>

                <Border x:Name="ErrorBorder" Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="8"
                        Padding="14" Margin="0,0,0,14" Visibility="Collapsed">
                    <TextBlock x:Name="ErrorText" Foreground="#DC2626" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </Border>

                <Border Style="{StaticResource WhiteCard}">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBox Grid.Column="0" Style="{StaticResource ReadableTextBox}" Text="{Binding FilterMachineId, Mode=TwoWay}" 
                                     Margin="0,0,12,0"/>
                            
                            <TextBox Grid.Column="1" Style="{StaticResource ReadableTextBox}" Text="{Binding FilterFromDate, Mode=TwoWay}" 
                                     Margin="0,0,12,0" Width="150"/>
                            
                            <TextBox Grid.Column="2" Style="{StaticResource ReadableTextBox}" Text="{Binding FilterToDate, Mode=TwoWay}" 
                                     Margin="0,0,12,0" Width="150"/>
                            
                            <StackPanel Grid.Column="3" Orientation="Horizontal">
                                <Button Content="Filtrar" Style="{StaticResource PrimaryButton}" Command="{Binding ApplyFiltersCommand}" Margin="0,0,8,0"/>
                                <Button Content="Limpar" Style="{StaticResource SecondaryButton}" Command="{Binding ClearFiltersCommand}"/>
                            </StackPanel>
                        </Grid>
                        
                        <DataGrid ItemsSource="{Binding Downtimes}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                                  SelectedItem="{Binding SelectedDowntime}" Height="350">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="*"/>
                                <DataGridTextColumn Header="Máquina" Binding="{Binding MachineName}" Width="1.5*"/>
                                <DataGridTextColumn Header="Início" Binding="{Binding StartTime}" Width="1.5*"/>
                                <DataGridTextColumn Header="Fim" Binding="{Binding EndTime}" Width="1.5*"/>
                                <DataGridTextColumn Header="Duração (s)" Binding="{Binding DurationSeconds}" Width="*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding StatusOriginDescription}" Width="1.2*"/>
                                <DataGridTextColumn Header="Motivo" Binding="{Binding Reason}" Width="1.5*"/>
                                <DataGridTextColumn Header="Classificável" Binding="{Binding CanClassify, Converter={StaticResource BoolToYesNo}}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        
                        <Separator Margin="0,14,0,14"/>
                        
                        <TextBlock Text="Classificação de Parada" Foreground="#111827" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Motivo" Foreground="#1F2937" FontSize="13" Margin="0,0,0,6"/>
                                <ComboBox SelectedItem="{Binding SelectedReasonId, Mode=TwoWay}" Margin="0,0,0,14">
                                    <ComboBoxItem Content=""/>
                                    <ComboBoxItem Content="1"/>
                                    <ComboBoxItem Content="2"/>
                                    <ComboBoxItem Content="3"/>
                                    <ComboBoxItem Content="4"/>
                                    <ComboBoxItem Content="5"/>
                                </ComboBox>
                                
                                <TextBlock Text="Motivo Informado" Foreground="#1F2937" FontSize="13" Margin="0,0,0,6"/>
                                <TextBox Style="{StaticResource ReadableTextBox}" Text="{Binding InformedReason, Mode=TwoWay}" Margin="0,0,0,14"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Observação" Foreground="#1F2937" FontSize="13" Margin="0,0,0,6"/>
                                <TextBox Style="{StaticResource ReadableTextBox}" Text="{Binding Observation, Mode=TwoWay}" Margin="0,0,0,14" AcceptsReturn="True" TextWrapping="Wrap" Height="60"/>
                                
                                <Button Content="Classificar" Style="{StaticResource PrimaryButton}" Command="{Binding ClassifyCommand}" Margin="0,0,0,14"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
