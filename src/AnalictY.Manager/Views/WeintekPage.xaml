<UserControl x:Class="AnalictY.Manager.Views.WeintekPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:AnalictY.Manager.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="760" d:DesignWidth="1280"
             Background="#F3F5F7"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <converters:BoolToYesNoConverter x:Key="BoolToYesNo"/>
        <converters:BoolToCollapsedConverter x:Key="BoolToCollapsed"/>
        
        <Style x:Key="WhiteCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="16" ShadowDepth="0"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B91C1C"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#334155"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#DC2626"/>
            <Setter Property="BorderBrush" Value="#FECACA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FEF2F2"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ReadableTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InfoBox" TargetType="Border">
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <!-- Header -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Width="40" Height="40" Margin="0,0,16,0" Background="Transparent" BorderThickness="0" Click="NavigateBackButton_Click">
                        <Path Data="M6 6L18 18M18 6L6 18" Stroke="#6B7280" StrokeThickness="2" Fill="Transparent" Width="20" Height="20" Stretch="Uniform"/>
                    </Button>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Browser Weintek" Foreground="#111827" FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="Receba payloads FHDX/cMT e transforme tags descobertas em tags do AnalictY." Foreground="#64748B" FontSize="14" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Notification -->
                <Border x:Name="NotificationBorder" Margin="0,0,0,24" Visibility="Collapsed">
                    <TextBlock x:Name="NotificationText" TextWrapping="Wrap" Padding="16" FontWeight="SemiBold"/>
                </Border>

                <!-- Config Section -->
                <Border Style="{StaticResource WhiteCard}" Margin="0,0,0,24">
                    <StackPanel>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Data="M13 10V3L4 14h7v7l9-11h-7z" Fill="#DC2626" Width="28" Height="28" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Conexão FHDX/cMT" Foreground="#111827" FontSize="20" FontWeight="Bold"/>
                                <TextBlock Text="Configure a origem esperada e copie a URL para o JS Object." Foreground="#6B7280" FontSize="14" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                        
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="Nome" Foreground="#374151" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBox Style="{StaticResource ReadableTextBox}" Text="{Binding Name, Mode=TwoWay}" Margin="0,0,0,16"/>
                                
                                <TextBlock Text="Gateway" Foreground="#374151" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBox Style="{StaticResource ReadableTextBox}" Text="{Binding Gateway, Mode=TwoWay}" Margin="0,0,0,16"/>
                                
                                <TextBlock Text="IP da FHDX" Foreground="#374151" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBox Style="{StaticResource ReadableTextBox}" Text="{Binding FhdxIp, Mode=TwoWay}" Margin="0,0,0,0"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Endpoint de ingestão" Foreground="#374151" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBox Style="{StaticResource ReadableTextBox}" Text="{Binding EndpointPath, Mode=TwoWay}" FontFamily="Consolas" FontSize="13" Margin="0,0,0,16"/>
                            </StackPanel>
                        </Grid>
                        
                        <Border Style="{StaticResource InfoBox}" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="URL para o JS Object" Foreground="#6B7280" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding EndpointUrl}" Foreground="#111827" FontSize="14" FontFamily="Consolas" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                            <CheckBox Content="Ativa" IsChecked="{Binding Enabled, Mode=TwoWay}" Margin="0,0,24,0" FontSize="14"/>
                            <CheckBox Content="Bloquear IP diferente" IsChecked="{Binding EnforceSourceIp, Mode=TwoWay}" Margin="0,0,24,0" FontSize="14"/>
                            <Border Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" Fill="#DC2626" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0"/>
                                    <TextBlock Text="Token obrigatório" Foreground="#B91C1C" FontSize="14" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                            <Button Content="Salvar" Style="{StaticResource PrimaryButton}" Command="{Binding SaveConfigCommand}" Margin="24,0,0,0" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Token Section -->
                <Border Style="{StaticResource WhiteCard}" Margin="0,0,0,24">
                    <StackPanel>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Data="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" Fill="#DC2626" Width="28" Height="28" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Autenticação do gateway" Foreground="#111827" FontSize="20" FontWeight="Bold"/>
                                <TextBlock Text="Use o token no header X-Gateway-Token do JS Object." Foreground="#6B7280" FontSize="14" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                        
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Style="{StaticResource InfoBox}" Margin="0,0,16,0">
                                <StackPanel>
                                    <TextBlock Text="Token" Foreground="#6B7280" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding TokenStatus}" Foreground="#111827" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Grid.Column="1" Style="{StaticResource InfoBox}" Margin="0,0,16,0">
                                <StackPanel>
                                    <TextBlock Text="Último acesso" Foreground="#6B7280" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding LastAccessAt}" Foreground="#111827" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Grid.Column="2" Style="{StaticResource InfoBox}">
                                <StackPanel>
                                    <TextBlock Text="Último IP" Foreground="#6B7280" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding LastSourceIp}" Foreground="#111827" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        
                        <Border Style="{StaticResource InfoBox}" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="URL de ping diagnóstico" Foreground="#6B7280" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding PingUrl}" Foreground="#111827" FontSize="14" FontFamily="Consolas" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="GeneratedTokenBorder" Background="#FFFBEB" BorderBrush="#FCD34D" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,20" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="Token gerado - copie agora" Foreground="#92400E" FontSize="11" FontWeight="SemiBold"/>
                                <Border Background="White" CornerRadius="6" Padding="12,8" Margin="0,8,0,0">
                                    <TextBlock Text="{Binding GeneratedToken}" Foreground="#111827" FontSize="14" FontFamily="Consolas" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Gerar token" Style="{StaticResource SecondaryButton}" Command="{Binding GenerateTokenCommand}" Margin="0,0,12,0"/>
                            <Button Content="Revogar token" Style="{StaticResource DangerButton}" Command="{Binding RevokeTokenCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Tags Section -->
                <Border Style="{StaticResource WhiteCard}" Margin="0,0,0,24">
                    <StackPanel>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Path Data="M12 2v20M2 12h20M4.93 4.93l14.14 14.14M19.07 4.93L4.93 19.07" Fill="#DC2626" Width="24" Height="24" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Tags descobertas" Foreground="#111827" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="{Binding TagsSummary}" Foreground="#6B7280" FontSize="14" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <TextBox Style="{StaticResource ReadableTextBox}" Text="{Binding Search, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                         Width="300" Margin="0,0,12,0" FontSize="13"/>
                                <Button Content="Atualizar" Style="{StaticResource PrimaryButton}" Command="{Binding RefreshCommand}" Background="#1E293B"/>
                            </StackPanel>
                        </Grid>
                        
                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" MaxHeight="430">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <DataGrid ItemsSource="{Binding FilteredTags}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" BorderThickness="0" Background="Transparent"
                                          RowBackground="White" AlternatingRowBackground="#F9FAFB">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#F9FAFB"/>
                                            <Setter Property="Foreground" Value="#6B7280"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="Padding" Value="12,8"/>
                                            <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="Padding" Value="12,8"/>
                                            <Setter Property="FontSize" Value="13"/>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Máquina" Binding="{Binding Machine}" Width="*"/>
                                        <DataGridTextColumn Header="Centro custo" Binding="{Binding CostCenter}" Width="*"/>
                                        <DataGridTextColumn Header="Tag" Binding="{Binding Tag}" Width="1.2*"/>
                                        <DataGridTextColumn Header="Valor" Binding="{Binding FormattedValue}" Width="*" FontFamily="Consolas"/>
                                        <DataGridTextColumn Header="Tipo" Binding="{Binding DataType}" Width="*"/>
                                        <DataGridTextColumn Header="Endereço" Binding="{Binding Address}" Width="1.2*" FontFamily="Consolas" FontSize="11"/>
                                        <DataGridTextColumn Header="Último recebimento" Binding="{Binding LastSeen}" Width="1.2*"/>
                                        <DataGridTemplateColumn Header="Ação" Width="Auto">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ContentControl>
                                                        <ContentControl.Style>
                                                            <Style TargetType="ContentControl">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Created}" Value="True">
                                                                        <Setter Property="ContentTemplate">
                                                                            <Setter.Value>
                                                                                <DataTemplate>
                                                                                    <Border Background="#D1FAE5" CornerRadius="6" Padding="12,6">
                                                                                        <StackPanel Orientation="Horizontal">
                                                                                            <Path Data="M20 6L9 17l-5-5" Fill="#059669" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0"/>
                                                                                            <TextBlock Text="Criada" Foreground="#047857" FontWeight="SemiBold" FontSize="13"/>
                                                                                        </StackPanel>
                                                                                    </Border>
                                                                                </DataTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Created}" Value="False">
                                                                        <Setter Property="ContentTemplate">
                                                                            <Setter.Value>
                                                                                <DataTemplate>
                                                                                    <Button Content="Criar tag" Style="{StaticResource SecondaryButton}" Padding="12,6" FontSize="13"
                                                                                            Command="{Binding DataContext.CreateTagCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                                            CommandParameter="{Binding}"/>
                                                                                </DataTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ContentControl.Style>
                                                    </ContentControl>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Payloads Section -->
                <Border Style="{StaticResource WhiteCard}" Margin="0,0,0,24">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Data="M20 6L9 17l-5-5" Fill="#059669" Width="20" Height="20" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Últimos payloads" Foreground="#111827" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="Amostra de diagnóstico; as tags ficam consolidadas na lista acima." Foreground="#6B7280" FontSize="14" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                        
                        <ScrollViewer MaxHeight="260">
                            <ItemsControl ItemsSource="{Binding RecentPayloads}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,12,12">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Summary}" Foreground="#111827" FontWeight="SemiBold" FontSize="13"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding ReceivedAt}" Foreground="#6B7280" FontSize="12"/>
                                                </Grid>
                                                <Border Background="#111827" CornerRadius="6" Padding="12">
                                                    <TextBlock Text="{Binding PayloadJson}" Foreground="#E5E7EB" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Audit Section -->
                <Border Style="{StaticResource WhiteCard}">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Data="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" Fill="#DC2626" Width="20" Height="20" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Auditoria do gateway" Foreground="#111827" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                        
                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" MaxHeight="260">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <DataGrid ItemsSource="{Binding Audits}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" BorderThickness="0" Background="Transparent"
                                          RowBackground="White" AlternatingRowBackground="#F9FAFB">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#F9FAFB"/>
                                            <Setter Property="Foreground" Value="#6B7280"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="Padding" Value="12,8"/>
                                            <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="Padding" Value="12,8"/>
                                            <Setter Property="FontSize" Value="13"/>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Data" Binding="{Binding CreatedAt}" Width="1.2*"/>
                                        <DataGridTextColumn Header="Gateway" Binding="{Binding Gateway}" Width="*"/>
                                        <DataGridTemplateColumn Header="Evento" Width="Auto">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border Background="{Binding StatusCode, Converter={StaticResource StatusCodeToBackground}}" CornerRadius="4" Padding="8,4">
                                                        <TextBlock Text="{Binding EventSummary}" Foreground="{Binding StatusCode, Converter={StaticResource StatusCodeToForeground}}" FontWeight="SemiBold" FontSize="12"/>
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="IP" Binding="{Binding SourceIp}" Width="*"/>
                                        <DataGridTextColumn Header="Motivo" Binding="{Binding Reason}" Width="1.5*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Modal -->
        <Grid x:Name="ModalOverlay" Background="#66000000" Visibility="Collapsed">
            <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="16" Padding="32"
                    Width="450" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#D1FAE5" CornerRadius="999" Width="48" Height="48" Margin="0,0,16,0">
                            <Path Data="M20 6L9 17l-5-5" Fill="#059669" Width="24" Height="24" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="ModalTitle" Text="Tag criada" Foreground="#111827" FontSize="20" FontWeight="Bold"/>
                            <TextBlock x:Name="ModalMessage" Text="" Foreground="#6B7280" FontSize="14" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                    <Button Content="OK" Style="{StaticResource SecondaryButton}" Click="CloseModal_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
