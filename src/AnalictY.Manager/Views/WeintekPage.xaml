<UserControl x:Class="AnalictY.Manager.Views.WeintekPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="760" d:DesignWidth="1280"
             Background="#F3F5F7"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="WhiteCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="ReadableTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Width="40" Height="40" Margin="0,0,16,0" Background="Transparent" BorderThickness="0" Click="NavigateBackButton_Click">
                        <Path Data="M6 6L18 18M18 6L6 18" Stroke="#6B7280" StrokeThickness="2" Fill="Transparent" Width="20" Height="20" Stretch="Uniform"/>
                    </Button>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Browser Weintek" Foreground="#111827" FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#64748B" FontSize="14" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="Atualizar" Style="{StaticResource PrimaryButton}" Command="{Binding RefreshCommand}"/>
                </Grid>

                <Border x:Name="ErrorBorder" Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="8"
                        Padding="14" Margin="0,0,0,14" Visibility="Collapsed">
                    <TextBlock x:Name="ErrorText" Foreground="#DC2626" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </Border>

                <!-- Config Section -->
                <Border Style="{StaticResource WhiteCard}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Conexão FHDX/cMT" Foreground="#111827" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Nome" Foreground="#1F2937" FontSize="13" Margin="0,0,0,6"/>
                                <TextBox Style="{StaticResource ReadableTextBox}" Text="{Binding Name, Mode=TwoWay}" Margin="0,0,0,14"/>
                                
                                <TextBlock Text="Gateway" Foreground="#1F2937" FontSize="13" Margin="0,0,0,6"/>
                                <TextBox Style="{StaticResource ReadableTextBox}" Text="{Binding Gateway, Mode=TwoWay}" Margin="0,0,0,14"/>
                                
                                <TextBlock Text="IP da FHDX" Foreground="#1F2937" FontSize="13" Margin="0,0,0,6"/>
                                <TextBox Style="{StaticResource ReadableTextBox}" Text="{Binding FhdxIp, Mode=TwoWay}" Margin="0,0,0,14"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Endpoint de ingestão" Foreground="#1F2937" FontSize="13" Margin="0,0,0,6"/>
                                <TextBox Style="{StaticResource ReadableTextBox}" Text="{Binding EndpointPath, Mode=TwoWay}" Margin="0,0,0,14"/>
                                
                                <CheckBox Content="Ativa" IsChecked="{Binding Enabled, Mode=TwoWay}" Margin="0,0,0,14"/>
                                <CheckBox Content="Bloquear IP diferente" IsChecked="{Binding EnforceSourceIp, Mode=TwoWay}" Margin="0,0,0,14"/>
                                <CheckBox Content="Token obrigatório" IsChecked="{Binding GatewayTokenRequired, Mode=TwoWay}" Margin="0,0,0,14"/>
                            </StackPanel>
                        </Grid>
                        
                        <Button Content="Salvar Configuração" Style="{StaticResource PrimaryButton}" Command="{Binding SaveConfigCommand}" HorizontalAlignment="Right" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Token Section -->
                <Border Style="{StaticResource WhiteCard}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Autenticação do Gateway" Foreground="#111827" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="Token" Foreground="#6B7280" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Config.TokenConfigured, Converter={StaticResource BoolToYesNo}}" Foreground="#111827" FontSize="13" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Grid.Column="1" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="Último Acesso" Foreground="#6B7280" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Config.LastAccessAt}" Foreground="#111827" FontSize="13" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Grid.Column="2" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="Último IP" Foreground="#6B7280" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Config.LastSourceIp}" Foreground="#111827" FontSize="13" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                            <Button Content="Gerar Token" Style="{StaticResource PrimaryButton}" Command="{Binding GenerateTokenCommand}" Margin="0,0,8,0"/>
                            <Button Content="Revogar Token" Style="{StaticResource DangerButton}" Command="{Binding RevokeTokenCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Tags Section -->
                <Border Style="{StaticResource WhiteCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="Tags Descobertas" Foreground="#111827" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding FilteredTags.Count, StringFormat=' ({0} visíveis)'}" Foreground="#64748B" FontSize="14" Margin="8,0,0,0"/>
                        </StackPanel>
                        
                        <TextBox Style="{StaticResource ReadableTextBox}" Text="{Binding Search, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 Margin="0,0,0,14"/>
                        
                        <DataGrid ItemsSource="{Binding FilteredTags}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                                  SelectedItem="{Binding SelectedTag}" Height="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Gateway" Binding="{Binding Gateway}" Width="*"/>
                                <DataGridTextColumn Header="Máquina" Binding="{Binding Machine}" Width="1.5*"/>
                                <DataGridTextColumn Header="TAG" Binding="{Binding Tag}" Width="1.5*"/>
                                <DataGridTextColumn Header="Endereço" Binding="{Binding Address}" Width="1.5*"/>
                                <DataGridTextColumn Header="Tipo" Binding="{Binding DataType}" Width="*"/>
                                <DataGridTextColumn Header="Criada" Binding="{Binding Created, Converter={StaticResource BoolToYesNo}}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                            <Button Content="Criar TAG" Style="{StaticResource PrimaryButton}" Command="{Binding CreateTagCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
