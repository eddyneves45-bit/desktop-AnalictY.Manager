<Page x:Class="AnalictY.Manager.Views.DatabaseBrowserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:views="clr-namespace:AnalictY.Manager.Views"
      mc:Ignorable="d"
      d:DesignHeight="760" d:DesignWidth="1280"
      Background="#22364B"
      FontFamily="Segoe UI">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Width="40" Height="40" Margin="0,0,16,0"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="BackButton_Click">
                        <Path Data="M6 6L18 18M18 6L6 18"
                              Stroke="#D8E2EC" StrokeThickness="2"
                              Fill="Transparent"
                              Width="20" Height="20" Stretch="Uniform"/>
                    </Button>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Banco de Dados" FontSize="28" FontWeight="Bold" Foreground="#F8FAFC"/>
                        <TextBlock Text="Status, tabelas, conexoes e acoes administrativas do banco."
                                   FontSize="14" Foreground="#BFD0E0" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <views:DatabaseView x:Name="DatabaseViewHost"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
