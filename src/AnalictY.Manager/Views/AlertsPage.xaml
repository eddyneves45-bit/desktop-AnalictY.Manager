<UserControl x:Class="AnalictY.Manager.Views.AlertsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="760" d:DesignWidth="1280"
             Background="#F3F5F7"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="WhiteCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="ReadableTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Width="40" Height="40" Margin="0,0,16,0" Background="Transparent" BorderThickness="0" Click="NavigateBackButton_Click">
                        <Path Data="M6 6L18 18M18 6L6 18" Stroke="#6B7280" StrokeThickness="2" Fill="Transparent" Width="20" Height="20" Stretch="Uniform"/>
                    </Button>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Gestão de Alertas" Foreground="#111827" FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#64748B" FontSize="14" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="Atualizar" Style="{StaticResource PrimaryButton}" Command="{Binding RefreshCommand}"/>
                </Grid>

                <Border x:Name="ErrorBorder" Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="8"
                        Padding="14" Margin="0,0,0,14" Visibility="Collapsed">
                    <TextBlock x:Name="ErrorText" Foreground="#DC2626" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Alerts -->
                    <Border Grid.Column="0" Style="{StaticResource WhiteCard}" Margin="0,0,12,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <TextBlock Text="Alertas" Foreground="#111827" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding FilteredAlerts.Count, StringFormat=' ({0})'}" Foreground="#64748B" FontSize="14" Margin="8,0,0,0"/>
                            </StackPanel>
                            
                            <TextBox Style="{StaticResource ReadableTextBox}" Text="{Binding Search, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                     Margin="0,0,0,14"/>
                            
                            <DataGrid ItemsSource="{Binding FilteredAlerts}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                                      SelectedItem="{Binding SelectedAlert}" Height="300">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Título" Binding="{Binding Title}" Width="1.5*"/>
                                    <DataGridTextColumn Header="Severidade" Binding="{Binding Severity}" Width="*"/>
                                    <DataGridTextColumn Header="Reconhecido" Binding="{Binding IsAcknowledged, Converter={StaticResource BoolToYesNo}}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                                <Button Content="Reconhecer" Style="{StaticResource PrimaryButton}" Command="{Binding AcknowledgeAlertCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Rules -->
                    <Border Grid.Column="1" Style="{StaticResource WhiteCard}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <TextBlock Text="Regras de Alerta" Foreground="#111827" FontSize="18" FontWeight="SemiBold"/>
                                <Button Content="Nova Regra" Style="{StaticResource PrimaryButton}" Command="{Binding CreateRuleCommand}" Margin="8,0,0,0"/>
                            </StackPanel>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Nome da Regra" Foreground="#1F2937" FontSize="13" Margin="0,0,0,6"/>
                                    <TextBox Style="{StaticResource ReadableTextBox}" Text="{Binding RuleName, Mode=TwoWay}" Margin="0,0,0,14"/>
                                    
                                    <TextBlock Text="TAG ID" Foreground="#1F2937" FontSize="13" Margin="0,0,0,6"/>
                                    <TextBox Style="{StaticResource ReadableTextBox}" Text="{Binding TagConfigId, Mode=TwoWay}" Margin="0,0,0,14"/>
                                    
                                    <TextBlock Text="Operador" Foreground="#1F2937" FontSize="13" Margin="0,0,0,6"/>
                                    <ComboBox SelectedItem="{Binding Operator, Mode=TwoWay}" Margin="0,0,0,14">
                                        <ComboBoxItem Content="&gt;"/>
                                        <ComboBoxItem Content="&lt;"/>
                                        <ComboBoxItem Content="="/>
                                        <ComboBoxItem Content="&gt;="/>
                                        <ComboBoxItem Content="&lt;="/>
                                        <ComboBoxItem Content="!="/>
                                    </ComboBox>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Limite" Foreground="#1F2937" FontSize="13" Margin="0,0,0,6"/>
                                    <TextBox Style="{StaticResource ReadableTextBox}" Text="{Binding LimitValue, Mode=TwoWay}" Margin="0,0,0,14"/>
                                    
                                    <TextBlock Text="Severidade" Foreground="#1F2937" FontSize="13" Margin="0,0,0,6"/>
                                    <ComboBox SelectedItem="{Binding Severity, Mode=TwoWay}" Margin="0,0,0,14">
                                        <ComboBoxItem Content="low"/>
                                        <ComboBoxItem Content="medium"/>
                                        <ComboBoxItem Content="high"/>
                                        <ComboBoxItem Content="critical"/>
                                    </ComboBox>
                                    
                                    <TextBlock Text="Mensagem" Foreground="#1F2937" FontSize="13" Margin="0,0,0,6"/>
                                    <TextBox Style="{StaticResource ReadableTextBox}" Text="{Binding Message, Mode=TwoWay}" Margin="0,0,0,14"/>
                                    
                                    <CheckBox Content="Ativa" IsChecked="{Binding IsActive, Mode=TwoWay}" Margin="0,0,0,14"/>
                                </StackPanel>
                            </Grid>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                <Button Content="Salvar" Style="{StaticResource PrimaryButton}" Command="{Binding SaveRuleCommand}" Margin="0,0,8,0"/>
                                <Button Content="Limpar" Style="{StaticResource SecondaryButton}" Command="{Binding CreateRuleCommand}"/>
                            </StackPanel>
                            
                            <Separator Margin="0,14,0,14"/>
                            
                            <DataGrid ItemsSource="{Binding Rules}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                                      SelectedItem="{Binding SelectedRule}" Height="150">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="1.5*"/>
                                    <DataGridTextColumn Header="TAG" Binding="{Binding TagName}" Width="*"/>
                                    <DataGridTextColumn Header="Severidade" Binding="{Binding Severity}" Width="*"/>
                                    <DataGridTextColumn Header="Ativa" Binding="{Binding IsActive, Converter={StaticResource BoolToYesNo}}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                                <Button Content="Editar" Style="{StaticResource SecondaryButton}" Command="{Binding EditRuleCommand}" Margin="0,0,8,0"/>
                                <Button Content="Excluir" Style="{StaticResource DangerButton}" Command="{Binding DeleteRuleCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
