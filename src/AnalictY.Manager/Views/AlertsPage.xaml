<UserControl x:Class="AnalictY.Manager.Views.AlertsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1280"
             Background="#F3F5F7"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="WhiteCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ReadableTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <!-- Header -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button Width="40" Height="40" Margin="0,0,16,0" Background="Transparent" BorderThickness="0" Click="NavigateBackButton_Click">
                            <Path Data="M10 19l-7-7m0 0l7-7m-7 7h18" Stroke="#6B7280" StrokeThickness="2" Fill="Transparent" Width="20" Height="20" Stretch="Uniform"/>
                        </Button>
                        <StackPanel>
                            <TextBlock Text="Alertas" Foreground="#111827" FontSize="30" FontWeight="Bold"/>
                            <TextBlock Text="{Binding PendingCount, StringFormat='{}{0} alerta(s) aguardando reconhecimento.'}" Foreground="#6B7280" FontSize="14" Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Guarda" Foreground="#374151" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox SelectedValue="{Binding RetentionDays}" BorderThickness="0" Background="Transparent" FontWeight="Bold" Foreground="#111827">
                                    <ComboBoxItem Content="1 dia" Tag="1"/>
                                    <ComboBoxItem Content="2 dias" Tag="2"/>
                                    <ComboBoxItem Content="3 dias" Tag="3"/>
                                    <ComboBoxItem Content="7 dias" Tag="7"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>
                        <Button Content="Nova regra" Style="{StaticResource PrimaryButton}" Command="{Binding CreateRuleCommand}">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M12 4v16m8-8H4" Stroke="White" StrokeThickness="2" Width="14" Height="14" Margin="0,0,8,0" Stretch="Uniform"/>
                                        <TextBlock Text="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Stats Cards -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Style="{StaticResource WhiteCard}" Margin="0,0,16,0">
                        <StackPanel>
                            <TextBlock Text="Pendentes" Foreground="#6B7280" FontSize="14"/>
                            <TextBlock Text="{Binding PendingCount}" Foreground="#111827" FontSize="30" FontWeight="Bold" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource WhiteCard}" Margin="0,0,16,0">
                        <StackPanel>
                            <TextBlock Text="Regras ativas" Foreground="#6B7280" FontSize="14"/>
                            <TextBlock Text="{Binding ActiveRulesCount}" Foreground="#111827" FontSize="30" FontWeight="Bold" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource WhiteCard}">
                        <StackPanel>
                            <TextBlock Text="Últimas notificações" Foreground="#6B7280" FontSize="14"/>
                            <TextBlock Text="{Binding TotalNotificationsCount}" Foreground="#111827" FontSize="30" FontWeight="Bold" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Telegram Section -->
                <Border Style="{StaticResource WhiteCard}" Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <Path Grid.Column="0" Data="M22 2L11 13M22 2L15 22L11 13M11 13L2 9L22 2" Stroke="#2563EB" StrokeThickness="2" Fill="Transparent" Width="20" Height="20" Margin="0,0,16,0" Stretch="Uniform" VerticalAlignment="Top"/>
                        
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Notificação Telegram" Foreground="#111827" FontWeight="SemiBold" FontSize="16"/>
                            <TextBlock Text="Teste o envio de alertas pelo bot do Telegram configurado." Foreground="#4B5563" FontSize="14" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding TelegramTestMessage}" Foreground="#374151" FontSize="14" FontWeight="Medium" Margin="0,8,0,0" Visibility="{Binding TelegramTestMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
                        </StackPanel>

                        <Button Grid.Column="2" Command="{Binding TestTelegramCommand}" IsEnabled="{Binding IsTestingTelegram, Converter={StaticResource InverseBoolConverter}}" Background="#2563EB" Foreground="White" BorderThickness="0" Padding="16,8" FontWeight="SemiBold" VerticalAlignment="Center">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M22 2L11 13M22 2L15 22L11 13M11 13L2 9L22 2" Stroke="White" StrokeThickness="2" Width="14" Height="14" Margin="0,0,8,0" Stretch="Uniform"/>
                                            <TextBlock Text="Testar Telegram"/>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- Notifications List -->
                <Border Style="{StaticResource WhiteCard}" Padding="0" Margin="0,0,0,24">
                    <StackPanel>
                        <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Padding="20,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Últimas 20 notificações" Foreground="#111827" FontWeight="SemiBold" FontSize="16"/>
                                    <TextBlock Text="Horários no fuso configurado" Foreground="#6B7280" FontSize="13" Margin="0,4,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="1" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Width="300" Padding="12,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Path Data="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" Stroke="#9CA3AF" StrokeThickness="2" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" FontSize="14" Padding="0,10"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <ItemsControl ItemsSource="{Binding FilteredAlerts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Padding="20,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="150"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" Stroke="{Binding SeverityColor}" StrokeThickness="2" Width="20" Height="20" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Top"/>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" Foreground="#111827" FontWeight="SemiBold" FontSize="14"/>
                                                    <TextBlock Text="{Binding Message}" Foreground="#4B5563" FontSize="14" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <TextBlock Grid.Column="1" Text="{Binding Severity}" Foreground="#4B5563" FontSize="13" TextAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="2" Text="{Binding CreatedAt}" Foreground="#4B5563" FontSize="13" TextAlignment="Center" VerticalAlignment="Center"/>
                                            
                                            <Grid Grid.Column="3" HorizontalAlignment="Right">
                                                <TextBlock Text="Reconhecido" Foreground="#059669" FontWeight="SemiBold" Visibility="{Binding IsAcknowledged, Converter={StaticResource BoolToVisibilityConverter}}" VerticalAlignment="Center"/>
                                                <Button Content="Reconhecer" Command="{Binding DataContext.AcknowledgeAlertCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Visibility="{Binding IsAcknowledged, Converter={StaticResource InverseBoolConverter}}" Padding="12,6" FontWeight="SemiBold" Foreground="#047857" BorderBrush="#059669" BorderThickness="1" Background="White">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Path Data="M5 13l4 4L19 7" Stroke="#059669" StrokeThickness="2" Width="14" Height="14" Margin="0,0,8,0" Stretch="Uniform"/>
                                                                    <ContentPresenter/>
                                                                </StackPanel>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Rules List -->
                <Border Style="{StaticResource WhiteCard}" Padding="0">
                    <StackPanel>
                        <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Padding="20,16">
                            <TextBlock Text="Regras configuradas" Foreground="#111827" FontWeight="SemiBold" FontSize="16"/>
                        </Border>
                        
                        <ItemsControl ItemsSource="{Binding Rules}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Padding="20,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="110"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" Stroke="#DC2626" StrokeThickness="2" Width="20" Height="20" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Top"/>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" Foreground="#111827" FontWeight="SemiBold" FontSize="14"/>
                                                    <TextBlock Text="{Binding ConditionText}" Foreground="#4B5563" FontSize="14" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <TextBlock Grid.Column="1" Text="{Binding Message}" Foreground="#4B5563" FontSize="13" VerticalAlignment="Center" Margin="12,0"/>
                                            <TextBlock Grid.Column="2" Text="{Binding ActiveText}" Foreground="{Binding ActiveColor}" FontSize="13" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                            
                                            <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Command="{Binding DataContext.EditRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Width="32" Height="32">
                                                    <Path Data="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" Stroke="#2563EB" StrokeThickness="2" Width="16" Height="16" Stretch="Uniform"/>
                                                </Button>
                                                <Button Command="{Binding DataContext.DeleteRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Width="32" Height="32" Margin="8,0,0,0">
                                                    <Path Data="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" Stroke="#DC2626" StrokeThickness="2" Width="16" Height="16" Stretch="Uniform"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Rule Modal Overlay -->
        <Grid Visibility="{Binding ShowModal, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#66000000" />
            <Border Style="{StaticResource WhiteCard}" Width="600" Height="Auto" MaxHeight="800" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Padding="24,20">
                        <TextBlock Text="{Binding IsEditingRule, Converter={StaticResource FormTitleConverter}, ConverterParameter='Regra'}" Foreground="#111827" FontSize="20" FontWeight="Bold"/>
                    </Border>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Border Padding="24">
                            <StackPanel>
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="Nome da regra *" Style="{StaticResource LabelText}"/>
                                    <TextBox Style="{StaticResource ReadableTextBox}" Text="{Binding RuleName, Mode=TwoWay}"/>
                                </StackPanel>
                                
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="TAG *" Style="{StaticResource LabelText}"/>
                                    <TextBox Style="{StaticResource ReadableTextBox}" Text="{Binding TagConfigId, Mode=TwoWay}"/>
                                </StackPanel>
                                
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Operador *" Style="{StaticResource LabelText}"/>
                                        <ComboBox SelectedValue="{Binding Operator}" Height="40">
                                            <ComboBoxItem Content=">"/>
                                            <ComboBoxItem Content=">="/>
                                            <ComboBoxItem Content="&lt;"/>
                                            <ComboBoxItem Content="&lt;="/>
                                            <ComboBoxItem Content="="/>
                                            <ComboBoxItem Content="!="/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Limite *" Style="{StaticResource LabelText}"/>
                                        <TextBox Style="{StaticResource ReadableTextBox}" Text="{Binding LimitValue, Mode=TwoWay}"/>
                                    </StackPanel>
                                </Grid>
                                
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="Severidade *" Style="{StaticResource LabelText}"/>
                                    <ComboBox SelectedValue="{Binding Severity}" Height="40">
                                        <ComboBoxItem Content="Baixa" Tag="low"/>
                                        <ComboBoxItem Content="Média" Tag="medium"/>
                                        <ComboBoxItem Content="Alta" Tag="high"/>
                                        <ComboBoxItem Content="Crítica" Tag="critical"/>
                                    </ComboBox>
                                </StackPanel>
                                
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="Mensagem ao operador *" Style="{StaticResource LabelText}"/>
                                    <TextBox Style="{StaticResource ReadableTextBox}" Text="{Binding Message, Mode=TwoWay}" Height="100" TextWrapping="Wrap" AcceptsReturn="True"/>
                                </StackPanel>
                                
                                <CheckBox Content="Regra ativa" IsChecked="{Binding IsActive, Mode=TwoWay}" FontWeight="SemiBold" Foreground="#374151"/>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                    
                    <Border Grid.Row="2" BorderBrush="#F3F4F6" BorderThickness="0,1,0,0" Padding="24,16" Background="#F9FAFB" CornerRadius="0,0,16,16">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancelar" Style="{StaticResource SecondaryButton}" Command="{Binding CloseModalCommand}" Margin="0,0,12,0" Width="100"/>
                            <Button Content="Salvar" Style="{StaticResource PrimaryButton}" Command="{Binding SaveRuleCommand}" Width="100"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
