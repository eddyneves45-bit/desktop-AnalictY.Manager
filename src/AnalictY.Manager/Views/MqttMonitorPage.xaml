<UserControl x:Class="AnalictY.Manager.Views.MqttMonitorPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="760" d:DesignWidth="1280"
             Background="#F3F5F7"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="WhiteCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="BlueButton" TargetType="Button">
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="ReadableCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="ReadableTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Width="40" Height="40" Margin="0,0,16,0" Background="Transparent" BorderThickness="0" Click="NavigateBackButton_Click">
                        <Path Data="M6 6L18 18M18 6L6 18" Stroke="#6B7280" StrokeThickness="2" Fill="Transparent" Width="20" Height="20" Stretch="Uniform"/>
                    </Button>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="MQTT Monitor" Foreground="#111827" FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#64748B" FontSize="14" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <ComboBox x:Name="ConnectionComboBox" ItemsSource="{Binding Connections}" DisplayMemberPath="DisplayName" 
                                  SelectedValuePath="Id" SelectedValue="{Binding SelectedConnectionId}" 
                                  Style="{StaticResource ReadableCombo}" Width="300" Margin="0,0,12,0" SelectionChanged="ConnectionComboBox_SelectionChanged"/>
                        <Button Content="Atualizar" Style="{StaticResource BlueButton}" Command="{Binding RefreshCommand}"/>
                    </StackPanel>
                </Grid>

                <Border x:Name="ErrorBorder" Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="8"
                        Padding="14" Margin="0,0,0,14" Visibility="Collapsed">
                    <TextBlock x:Name="ErrorText" Foreground="#DC2626" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Publish Section -->
                    <Border Grid.Column="0" Style="{StaticResource WhiteCard}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Publicar Mensagem" Foreground="#111827" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            
                            <TextBlock Text="Tópico" Foreground="#1F2937" FontSize="13" Margin="0,0,0,6"/>
                            <TextBox x:Name="PublishTopicTextBox" Style="{StaticResource ReadableTextBox}" Text="{Binding PublishTopic, Mode=TwoWay}" Margin="0,0,0,14"/>

                            <TextBlock Text="Payload" Foreground="#1F2937" FontSize="13" Margin="0,0,0,6"/>
                            <TextBox x:Name="PublishPayloadTextBox" Style="{StaticResource ReadableTextBox}" Text="{Binding PublishPayload, Mode=TwoWay}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,14"/>

                            <TextBlock Text="QoS" Foreground="#1F2937" FontSize="13" Margin="0,0,0,6"/>
                            <ComboBox SelectedIndex="{Binding PublishQos, Mode=TwoWay}" Style="{StaticResource ReadableCombo}" Margin="0,0,0,14">
                                <ComboBoxItem Content="0 - At most once"/>
                                <ComboBoxItem Content="1 - At least once"/>
                                <ComboBoxItem Content="2 - Exactly once"/>
                            </ComboBox>

                            <CheckBox Content="Retain" IsChecked="{Binding PublishRetain, Mode=TwoWay}" Margin="0,0,0,14"/>

                            <Button Content="Publicar" Style="{StaticResource PrimaryButton}" Command="{Binding PublishCommand}"/>
                        </StackPanel>
                    </Border>

                    <!-- Subscribe/Unsubscribe Section -->
                    <Border Grid.Column="1" Style="{StaticResource WhiteCard}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Gerenciar Tópicos" Foreground="#111827" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            
                            <TextBlock Text="Tópico" Foreground="#1F2937" FontSize="13" Margin="0,0,0,6"/>
                            <TextBox x:Name="SubscribeTopicTextBox" Style="{StaticResource ReadableTextBox}" Text="{Binding SubscribeTopic, Mode=TwoWay}" Margin="0,0,0,14"/>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="Inscrever" Style="{StaticResource BlueButton}" Command="{Binding SubscribeCommand}"/>
                                <Button Content="Remover" Style="{StaticResource SecondaryButton}" Command="{Binding UnsubscribeCommand}"/>
                            </StackPanel>

                            <TextBlock Text="Tópicos Descobertos" Foreground="#111827" FontSize="16" FontWeight="SemiBold" Margin="0,24,0,12"/>
                            <ItemsControl ItemsSource="{Binding DiscoveredTopics}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                                            <TextBlock Text="{Binding}" Foreground="#111827" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Clients Section -->
                    <Border Grid.Column="2" Style="{StaticResource WhiteCard}">
                        <StackPanel>
                            <TextBlock Text="Clientes Conectados" Foreground="#111827" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            <ItemsControl ItemsSource="{Binding Clients}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding ClientId}" Foreground="#111827" FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding LastSeen}" Foreground="#64748B" FontSize="12" Margin="0,2,0,0"/>
                                                <TextBlock Text="{Binding Connected, Converter={StaticResource BoolToYesNo}}" Foreground="#64748B" FontSize="12" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Tags Section -->
                <Border Style="{StaticResource WhiteCard}" Margin="0,18,0,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="TAGs MQTT" Foreground="#111827" FontSize="18" FontWeight="SemiBold"/>
                            <TextBox Grid.Column="1" Width="200" Style="{StaticResource ReadableTextBox}" Text="{Binding TagFilter, Mode=TwoWay}" Margin="0,0,12,0"/>
                        </Grid>
                        
                        <DataGrid ItemsSource="{Binding Tags}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="1.5*"/>
                                <DataGridTextColumn Header="Endereço" Binding="{Binding Address}" Width="2*"/>
                                <DataGridTextColumn Header="Tipo" Binding="{Binding DataType}" Width="*"/>
                                <DataGridTextColumn Header="Scan Rate" Binding="{Binding ScanRate}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Notification Modal -->
        <Grid x:Name="NotificationOverlay" Background="#66000000" Visibility="Collapsed">
            <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Padding="26"
                    Width="420" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock x:Name="NotificationTitle" Text="Aviso" Foreground="#111827" FontSize="22" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock x:Name="NotificationMessage" Foreground="#475569" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,22"/>
                    <Button Content="OK" Width="100" HorizontalAlignment="Right" Style="{StaticResource PrimaryButton}" Click="CloseNotification_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
