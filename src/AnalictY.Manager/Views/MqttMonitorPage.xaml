<Page x:Class="AnalictY.Manager.Views.MqttMonitorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="760" d:DesignWidth="1280"
      Background="#F3F5F7"
      FontFamily="Segoe UI">
    
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <Grid Margin="0,0,0,24">
                    <StackPanel Orientation="Horizontal">
                        <Button Width="40" Height="40" Margin="0,0,16,0"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Click="BackButton_Click">
                            <Path Data="M6 6L18 18M18 6L6 18" 
                                  Stroke="#6B7280" StrokeThickness="2" 
                                  Fill="Transparent" 
                                  Width="20" Height="20" Stretch="Uniform"/>
                        </Button>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="MQTT" FontSize="28" FontWeight="Bold" Foreground="#111827"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="24" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="Configuração MQTT" FontSize="18" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,16"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Nome:" Foreground="#374151" Margin="0,0,0,8"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                     BorderBrush="#D1D5DB" BorderThickness="1" Padding="8"
                                     Text="MQTT AWS IoT"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Broker Host:" Foreground="#374151" Margin="0,0,0,8"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                     BorderBrush="#D1D5DB" BorderThickness="1" Padding="8"
                                     Text="a1b2c3d4wxyz-ats.iot.sa-east-1.amazonaws.com"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Client ID:" Foreground="#374151" Margin="0,0,0,8"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                     BorderBrush="#D1D5DB" BorderThickness="1" Padding="8"
                                     Text="scada-mes-client"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Porta:" Foreground="#374151" Margin="0,0,0,8"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                     BorderBrush="#D1D5DB" BorderThickness="1" Padding="8"
                                     Text="8883"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Usuário:" Foreground="#374151" Margin="0,0,0,8"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                     BorderBrush="#D1D5DB" BorderThickness="1" Padding="8"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Senha:" Foreground="#374151" Margin="0,0,0,8"/>
                            <PasswordBox Grid.Row="5" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                         BorderBrush="#D1D5DB" BorderThickness="1" Padding="8"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Usar TLS/SSL:" Foreground="#374151" Margin="0,0,0,8"/>
                            <CheckBox Grid.Row="6" Grid.Column="1" Margin="0,0,0,16" IsChecked="True"
                                      Content="Habilitar TLS/SSL"/>

                            <TextBlock Grid.Row="7" Grid.Column="0" Text="CA / Root CA:" Foreground="#374151" Margin="0,0,0,8"/>
                            <TextBox Grid.Row="7" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                     BorderBrush="#D1D5DB" BorderThickness="1" Padding="8"
                                     Text="./certificates/aws-root-ca.pem"/>

                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Certificado cliente:" Foreground="#374151" Margin="0,0,0,8"/>
                            <TextBox Grid.Row="8" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                     BorderBrush="#D1D5DB" BorderThickness="1" Padding="8"
                                     Text="./certificates/mqtt_client.crt"/>

                            <TextBlock Grid.Row="9" Grid.Column="0" Text="Chave privada:" Foreground="#374151" Margin="0,0,0,8"/>
                            <TextBox Grid.Row="9" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                     BorderBrush="#D1D5DB" BorderThickness="1" Padding="8"
                                     Text="./certificates/mqtt_client.key"/>

                            <TextBlock Grid.Row="10" Grid.Column="0" Text="Tópicos:" Foreground="#374151" Margin="0,0,0,8"/>
                            <TextBox Grid.Row="10" Grid.Column="1" Height="60" Margin="0,0,0,16"
                                     BorderBrush="#D1D5DB" BorderThickness="1" Padding="8"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     Text="mes/production/+, mes/machines/+, mes/alerts/+"/>

                            <TextBlock Grid.Row="11" Grid.Column="0" Text="QoS:" Foreground="#374151" Margin="0,0,0,8"/>
                            <ComboBox Grid.Row="11" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                      BorderBrush="#D1D5DB" BorderThickness="1" Padding="8">
                                <ComboBoxItem Content="0"/>
                                <ComboBoxItem Content="1" IsSelected="True"/>
                                <ComboBoxItem Content="2"/>
                            </ComboBox>

                            <TextBlock Grid.Row="12" Grid.Column="0" Text="Conexão Ativa:" Foreground="#374151" Margin="0,0,0,8"/>
                            <CheckBox Grid.Row="12" Grid.Column="1" Margin="0,0,0,16" IsChecked="True"
                                      Content="Habilitar conexão"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Content="Limpar" 
                                    Background="#E5E7EB" Foreground="#374151"
                                    BorderThickness="0" Padding="16,8" Margin="0,0,8,0"
                                    Cursor="Hand"/>
                            <Button Content="Testar Conexão" 
                                    Background="#10B981" Foreground="White"
                                    BorderThickness="0" Padding="16,8" Margin="0,0,8,0"
                                    Cursor="Hand"/>
                            <Button Content="Salvar" 
                                    Background="#DC2626" Foreground="White"
                                    BorderThickness="0" Padding="16,8"
                                    Cursor="Hand"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
