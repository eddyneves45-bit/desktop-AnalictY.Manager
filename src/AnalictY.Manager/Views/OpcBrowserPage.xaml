<Page x:Class="AnalictY.Manager.Views.OpcBrowserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="760" d:DesignWidth="1280"
      Background="#F3F5F7"
      FontFamily="Segoe UI">
    
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <!-- Header -->
                <Grid Margin="0,0,0,24">
                    <StackPanel Orientation="Horizontal">
                        <Button Width="40" Height="40" Margin="0,0,16,0"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Click="BackButton_Click">
                            <Path Data="M6 6L18 18M18 6L6 18" 
                                  Stroke="#6B7280" StrokeThickness="2" 
                                  Fill="Transparent" 
                                  Width="20" Height="20" Stretch="Uniform"/>
                        </Button>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="OPC UA" 
                                       FontSize="28" FontWeight="Bold" 
                                       Foreground="#111827"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Connection Form -->
                <Border Background="White" 
                        BorderBrush="#E5E7EB" 
                        BorderThickness="1" 
                        CornerRadius="12" 
                        Padding="24"
                        Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="Configuração de Conexão OPC UA" 
                                   FontSize="18" 
                                   FontWeight="SemiBold" 
                                   Foreground="#111827"
                                   Margin="0,0,0,16"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Nome:" 
                                       Foreground="#374151" Margin="0,0,0,8"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                     BorderBrush="#D1D5DB" BorderThickness="1" Padding="8"
                                     Text="opc"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="URL do Servidor:" 
                                       Foreground="#374151" Margin="0,0,0,8"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                     BorderBrush="#D1D5DB" BorderThickness="1" Padding="8"
                                     Text="opc.tcp://DESKTOP-EDDY:4840/G01"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Política de Segurança:" 
                                       Foreground="#374151" Margin="0,0,0,8"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                      BorderBrush="#D1D5DB" BorderThickness="1" Padding="8">
                                <ComboBoxItem Content="None" IsSelected="True"/>
                                <ComboBoxItem Content="Basic128"/>
                                <ComboBoxItem Content="Basic128Rsa15"/>
                                <ComboBoxItem Content="Basic256"/>
                                <ComboBoxItem Content="Basic256Sha256"/>
                            </ComboBox>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Modo de Segurança:" 
                                       Foreground="#374151" Margin="0,0,0,8"/>
                            <ComboBox Grid.Row="3" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                      BorderBrush="#D1D5DB" BorderThickness="1" Padding="8">
                                <ComboBoxItem Content="None" IsSelected="True"/>
                                <ComboBoxItem Content="Sign"/>
                                <ComboBoxItem Content="SignAndEncrypt"/>
                            </ComboBox>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Usuário (opcional):" 
                                       Foreground="#374151" Margin="0,0,0,8"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                     BorderBrush="#D1D5DB" BorderThickness="1" Padding="8"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Senha (opcional):" 
                                       Foreground="#374151" Margin="0,0,0,8"/>
                            <PasswordBox Grid.Row="5" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                         BorderBrush="#D1D5DB" BorderThickness="1" Padding="8"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Caminho do Certificado:" 
                                       Foreground="#374151" Margin="0,0,0,8"/>
                            <Grid Grid.Row="6" Grid.Column="1" Margin="0,0,0,16">
                                <TextBox Height="36" BorderBrush="#D1D5DB" BorderThickness="1" Padding="8"
                                         Margin="0,0,80,0"/>
                                <Button Content="..." Width="60" Height="36" HorizontalAlignment="Right"
                                        Background="#F3F4F6" BorderBrush="#D1D5DB" BorderThickness="1"/>
                            </Grid>

                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Caminho da Chave Privada:" 
                                       Foreground="#374151" Margin="0,0,0,8"/>
                            <Grid Grid.Row="7" Grid.Column="1" Margin="0,0,0,16">
                                <TextBox Height="36" BorderBrush="#D1D5DB" BorderThickness="1" Padding="8"
                                         Margin="0,0,80,0"/>
                                <Button Content="..." Width="60" Height="36" HorizontalAlignment="Right"
                                        Background="#F3F4F6" BorderBrush="#D1D5DB" BorderThickness="1"/>
                            </Grid>

                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Intervalo de Atualização (ms):" 
                                       Foreground="#374151" Margin="0,0,0,8"/>
                            <TextBox Grid.Row="8" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                     BorderBrush="#D1D5DB" BorderThickness="1" Padding="8"
                                     Text="1000"/>

                            <TextBlock Grid.Row="9" Grid.Column="0" Text="Conexão Ativa:" 
                                       Foreground="#374151" Margin="0,0,0,8"/>
                            <CheckBox Grid.Row="9" Grid.Column="1" Margin="0,0,0,16" IsChecked="True"
                                      Content="Habilitar conexão"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Content="Limpar" 
                                    Background="#E5E7EB" Foreground="#374151"
                                    BorderThickness="0" Padding="16,8" Margin="0,0,8,0"
                                    Cursor="Hand"/>
                            <Button Content="Testar Conexão" 
                                    Background="#10B981" Foreground="White"
                                    BorderThickness="0" Padding="16,8" Margin="0,0,8,0"
                                    Cursor="Hand"/>
                            <Button Content="Salvar" 
                                    Background="#DC2626" Foreground="White"
                                    BorderThickness="0" Padding="16,8"
                                    Cursor="Hand"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Saved Connections -->
                <Border Background="White" 
                        BorderBrush="#E5E7EB" 
                        BorderThickness="1" 
                        CornerRadius="12" 
                        Padding="24">
                    <StackPanel>
                        <TextBlock Text="Conexões Salvas" 
                                   FontSize="18" 
                                   FontWeight="SemiBold" 
                                   Foreground="#111827"
                                   Margin="0,0,0,16"/>
                        <TextBlock Text="Nenhuma conexão salva" 
                                   FontSize="14" 
                                   Foreground="#6B7280"
                                   HorizontalAlignment="Center"
                                   Margin="0,40,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
