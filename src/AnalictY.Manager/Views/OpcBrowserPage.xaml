<Page x:Class="AnalictY.Manager.Views.OpcBrowserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="760" d:DesignWidth="1280"
      Background="#F3F5F7"
      FontFamily="Segoe UI">

    <Page.Resources>
        <Style x:Key="WhiteCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Width="40" Height="40" Margin="0,0,16,0"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="BackButton_Click">
                        <Path Data="M6 6L18 18M18 6L6 18"
                              Stroke="#6B7280" StrokeThickness="2"
                              Fill="Transparent"
                              Width="20" Height="20" Stretch="Uniform"/>
                    </Button>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Browser OPC UA" Foreground="#111827" FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#64748B" FontSize="14" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Content="Atualizar" Style="{StaticResource SecondaryButton}" Command="{Binding RefreshCommand}"/>
                        <Button Content="Raiz" Style="{StaticResource PrimaryButton}" Click="RootButton_Click"/>
                    </StackPanel>
                </Grid>

                <Border Style="{StaticResource WhiteCard}" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Conexao" Foreground="#1F2937" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding Connections}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding SelectedConnectionId, Mode=TwoWay}"
                                  MinHeight="36"
                                  Foreground="#111827"
                                  Background="White"
                                  BorderBrush="#CBD5E1"
                                  Padding="8,6"/>
                        <Button Grid.Column="2" Content="Voltar" Style="{StaticResource SecondaryButton}" Margin="12,0,0,0" Click="BackNodeButton_Click"/>
                    </Grid>
                </Border>

                <Border Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="8"
                        Padding="14" Margin="0,0,0,14">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasError}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </Border>

                <Border Style="{StaticResource WhiteCard}">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Nos OPC UA" Foreground="#111827" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="{Binding CurrentNodeId}" Foreground="#64748B" FontSize="12" VerticalAlignment="Center"/>
                        </Grid>

                        <ListView ItemsSource="{Binding Nodes}"
                                  SelectedItem="{Binding SelectedNode, Mode=TwoWay}"
                                  MouseDoubleClick="NodesList_MouseDoubleClick"
                                  MinHeight="420"
                                  BorderBrush="#E5E7EB"
                                  BorderThickness="1"
                                  Background="White">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="" Width="76">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Abrir"
                                                        Padding="10,4"
                                                        Click="OpenNodeButton_Click"
                                                        Tag="{Binding}"
                                                        IsEnabled="{Binding HasChildren}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Nome" Width="240" DisplayMemberBinding="{Binding Name}"/>
                                    <GridViewColumn Header="Classe" Width="120" DisplayMemberBinding="{Binding Type}"/>
                                    <GridViewColumn Header="NodeId" Width="520" DisplayMemberBinding="{Binding NodeId}"/>
                                    <GridViewColumn Header="Filhos" Width="80" DisplayMemberBinding="{Binding HasChildren}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
