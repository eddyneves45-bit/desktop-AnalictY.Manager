<Page x:Class="AnalictY.Manager.Views.AlertsConfigPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="760" d:DesignWidth="1280"
      Background="#F3F5F7"
      FontFamily="Segoe UI">
    
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <Grid Margin="0,0,0,24">
                    <StackPanel Orientation="Horizontal">
                        <Button Width="40" Height="40" Margin="0,0,16,0"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Click="BackButton_Click">
                            <Path Data="M19 12H5M12 19l-7-7 7-7" 
                                  Stroke="#6B7280" StrokeThickness="2" 
                                  Fill="Transparent" 
                                  Width="20" Height="20" Stretch="Uniform"/>
                        </Button>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Alertas" FontSize="28" FontWeight="Bold" Foreground="#111827"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="24" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="Configuração de Alertas" FontSize="18" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,16"/>
                        <TextBlock Text="Regras e reconhecimento" FontSize="14" Foreground="#6B7280" Margin="0,0,0,16"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Nome do Alerta:" Foreground="#374151" Margin="0,0,0,8"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                     BorderBrush="#D1D5DB" BorderThickness="1" Padding="8"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Condição:" Foreground="#374151" Margin="0,0,0,8"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                      BorderBrush="#D1D5DB" BorderThickness="1" Padding="8">
                                <ComboBoxItem Content="Máquina parada"/>
                                <ComboBoxItem Content="Produção abaixo do alvo"/>
                                <ComboBoxItem Content="Temperatura alta"/>
                                <ComboBoxItem Content="Pressão baixa"/>
                            </ComboBox>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Severidade:" Foreground="#374151" Margin="0,0,0,8"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                      BorderBrush="#D1D5DB" BorderThickness="1" Padding="8">
                                <ComboBoxItem Content="Baixa"/>
                                <ComboBoxItem Content="Média"/>
                                <ComboBoxItem Content="Alta"/>
                                <ComboBoxItem Content="Crítica"/>
                            </ComboBox>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Máquina:" Foreground="#374151" Margin="0,0,0,8"/>
                            <ComboBox Grid.Row="3" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                      BorderBrush="#D1D5DB" BorderThickness="1" Padding="8">
                                <ComboBoxItem Content="Todas as máquinas"/>
                            </ComboBox>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Notificar via:" Foreground="#374151" Margin="0,0,0,8"/>
                            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,16">
                                <CheckBox Content="Telegram" Margin="0,0,16,0" IsChecked="True"/>
                                <CheckBox Content="Email" Margin="0,0,16,0"/>
                                <CheckBox Content="SMS"/>
                            </StackPanel>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Ativo:" Foreground="#374151" Margin="0,0,0,8"/>
                            <CheckBox Grid.Row="5" Grid.Column="1" Margin="0,0,0,16" IsChecked="True"
                                      Content="Habilitar alerta"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Content="Limpar" 
                                    Background="#E5E7EB" Foreground="#374151"
                                    BorderThickness="0" Padding="16,8" Margin="0,0,8,0"
                                    Cursor="Hand"/>
                            <Button Content="Adicionar Alerta" 
                                    Background="#EF4444" Foreground="White"
                                    BorderThickness="0" Padding="16,8"
                                    Cursor="Hand"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
