<UserControl x:Class="AnalictY.Manager.Views.UpdatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,20">
            <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Atualizações"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="Gerenciamento de versões do AnalictY Server"
                                   Style="{StaticResource SectionSubtitleStyle}"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Verificar Atualizações"
                                Command="{Binding CheckUpdatesCommand}"
                                Margin="0,0,10,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecking}" Value="True">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" CornerRadius="18" Margin="0,0,16,16" Padding="18" BorderThickness="0" Background="{StaticResource KpiBlueBrush}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.12" Color="#000000" />
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Versão Atual" FontSize="13" FontWeight="SemiBold" Foreground="#EAF2FF" />
                        <TextBlock Text="{Binding CurrentVersion}" FontSize="24" FontWeight="Black" Foreground="White" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" CornerRadius="18" Margin="0,0,16,16" Padding="18" BorderThickness="0" Background="{StaticResource KpiOrangeBrush}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.12" Color="#000000" />
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Canal" FontSize="13" FontWeight="SemiBold" Foreground="#EAF2FF" />
                        <TextBlock Text="{Binding Channel}" FontSize="24" FontWeight="Black" Foreground="White" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" CornerRadius="18" Margin="0,0,16,16" Padding="18" BorderThickness="0" Background="{StaticResource KpiGreenBrush}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.12" Color="#000000" />
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Última Versão" FontSize="13" FontWeight="SemiBold" Foreground="#EAF2FF" />
                        <TextBlock Text="{Binding LatestVersion}" FontSize="24" FontWeight="Black" Foreground="White" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,0,0,18">
                <StackPanel>
                    <TextBlock Text="Status da Atualização"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ContentTextBrush}"
                               Margin="0,0,0,16" />
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="14"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16" />
                    <Border Background="#F0FDF4"
                            BorderBrush="#86EFAC"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="16">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasUpdate}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="Nova versão disponível!"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#166534"
                                       Margin="0,0,0,8" />
                            <TextBlock Text="{Binding ReleaseNotes}"
                                       FontSize="13"
                                       Foreground="#15803D"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,0,0,18">
                <StackPanel>
                    <TextBlock Text="Informações"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ContentTextBrush}"
                               Margin="0,0,0,16" />
                    <TextBlock Text="A aplicação de atualizações será implementada em uma fase futura."
                               FontSize="13"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
