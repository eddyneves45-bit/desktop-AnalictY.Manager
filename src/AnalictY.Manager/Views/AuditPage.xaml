<UserControl x:Class="AnalictY.Manager.Views.AuditPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="760" d:DesignWidth="1280"
             Background="#F3F5F7"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="WhiteCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ReadableTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <!-- Header -->
                <Border Style="{StaticResource WhiteCard}" Margin="0,0,0,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Width="40" Height="40" Margin="0,0,12,0" Background="Transparent" BorderThickness="0" Click="NavigateBackButton_Click">
                            <Path Data="M10 19l-7-7m0 0l7-7m-7 7h18" Stroke="#6B7280" StrokeThickness="2" Fill="Transparent" Width="20" Height="20" Stretch="Uniform"/>
                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Auditoria" Foreground="#111827" FontSize="24" FontWeight="Bold"/>
                            <TextBlock Text="Alterações administrativas recentes no sistema" Foreground="#6B7280" FontSize="14" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="2" Content="Atualizar" Style="{StaticResource PrimaryButton}" Command="{Binding RefreshCommand}" Margin="12,0,0,0"/>
                    </Grid>
                </Border>

                <Border x:Name="ErrorBorder" Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="8"
                        Padding="14" Margin="0,0,0,14" Visibility="Collapsed">
                    <TextBlock x:Name="ErrorText" Foreground="#DC2626" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </Border>

                <Border Style="{StaticResource WhiteCard}">
                    <StackPanel>
                        <Border Background="#F8FAFC" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBox Grid.Column="0" Style="{StaticResource ReadableTextBox}" Text="{Binding Search, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                         Margin="0,0,12,0"/>
                                
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Exibindo " Foreground="#6B7280" FontSize="13"/>
                                    <TextBlock Text="{Binding FilteredLogs.Count}" Foreground="#111827" FontSize="13" FontWeight="SemiBold" Margin="4,0"/>
                                    <TextBlock Text=" de " Foreground="#6B7280" FontSize="13"/>
                                    <TextBlock Text="{Binding Logs.Count}" Foreground="#111827" FontSize="13" FontWeight="SemiBold" Margin="4,0"/>
                                    <TextBlock Text=" registros" Foreground="#6B7280" FontSize="13"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <DataGrid ItemsSource="{Binding FilteredLogs}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                                  MinHeight="450" HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowHeaderWidth="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Data/Hora" Binding="{Binding CreatedAt}" Width="1.2*"/>
                                <DataGridTextColumn Header="Usuário" Binding="{Binding Username}" Width="0.9*"/>
                                <DataGridTextColumn Header="Perfil" Binding="{Binding Role}" Width="0.7*"/>
                                <DataGridTextColumn Header="Ação" Binding="{Binding Action}" Width="0.7*"/>
                                <DataGridTextColumn Header="Rota" Binding="{Binding Path}" Width="2.4*"/>
                                <DataGridTextColumn Header="HTTP" Binding="{Binding StatusCode}" Width="0.6*"/>
                                <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="1*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
