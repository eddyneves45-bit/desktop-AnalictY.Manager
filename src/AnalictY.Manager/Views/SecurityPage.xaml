<Page x:Class="AnalictY.Manager.Views.SecurityPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="SecurityPage"
      Background="{StaticResource SurfaceBrush}">
    <Page.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>
        <Style x:Key="TitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ContentTextBrush}" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="MutedStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Seguranca" Style="{StaticResource TitleStyle}" />
                        <TextBlock Text="Autenticacao em duas etapas do usuario atual no AnalictY Server." Style="{StaticResource MutedStyle}" Margin="0,6,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="Atualizar" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="14,8" />
                </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="MFA" Style="{StaticResource TitleStyle}" />
                    <UniformGrid Columns="2" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="Estado" Style="{StaticResource MutedStyle}" />
                            <TextBlock Text="{Binding MfaStateLabel}" Foreground="{StaticResource ContentTextBrush}" FontSize="24" FontWeight="SemiBold" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Operacao" Style="{StaticResource MutedStyle}" />
                            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource ContentTextBrush}" FontSize="14" Margin="0,8,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </UniformGrid>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#EF4444" TextWrapping="Wrap" Margin="0,14,0,0" />

                    <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                        <Button Content="Configurar MFA" Command="{Binding StartSetupCommand}" Style="{StaticResource PrimaryButtonStyle}" Padding="14,9" Margin="0,0,10,0" />
                        <Button Content="Desativar MFA" Command="{Binding DisableCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="14,9" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Visibility="{Binding HasSetup, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Configuracao MFA" Style="{StaticResource TitleStyle}" />
                    <TextBlock Text="Cadastre a chave manual abaixo no seu aplicativo autenticador. Depois informe o codigo de 6 digitos." Style="{StaticResource MutedStyle}" Margin="0,8,0,14" />

                    <TextBlock Text="Chave manual" Style="{StaticResource MutedStyle}" />
                    <TextBox Text="{Binding Secret}" IsReadOnly="True" Background="{StaticResource InputBrush}" Foreground="{StaticResource ContentTextBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="10" Margin="0,6,0,12" />

                    <TextBlock Text="URI otpauth" Style="{StaticResource MutedStyle}" />
                    <TextBox Text="{Binding OtpAuthUrl}" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="70" Background="{StaticResource InputBrush}" Foreground="{StaticResource ContentTextBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="10" Margin="0,6,0,12" />

                    <TextBlock Text="Codigo MFA" Style="{StaticResource MutedStyle}" />
                    <TextBox Text="{Binding MfaCode, UpdateSourceTrigger=PropertyChanged}" MaxLength="6" Width="180" HorizontalAlignment="Left" Background="{StaticResource InputBrush}" Foreground="{StaticResource ContentTextBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="10" FontSize="18" HorizontalContentAlignment="Center" Margin="0,6,0,12" />

                    <Button Content="Ativar MFA" Command="{Binding EnableCommand}" Style="{StaticResource PrimaryButtonStyle}" Padding="14,9" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Observacoes" Style="{StaticResource TitleStyle}" />
                    <TextBlock Text="Ao ativar MFA, o Server encerra as sessoes atuais. Faca login novamente no Manager usando usuario, senha e codigo MFA." Style="{StaticResource MutedStyle}" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
