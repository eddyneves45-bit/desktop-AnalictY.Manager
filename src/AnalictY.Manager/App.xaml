<Application x:Class="AnalictY.Manager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AnalictY.Manager"
             xmlns:converters="clr-namespace:AnalictY.Manager.Converters">
    <Application.Resources>
        <!-- Main Theme Colors - Industrial Dark Mode -->
        <SolidColorBrush x:Key="SurfaceBrush" Color="#243447" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#172539" />
        <SolidColorBrush x:Key="CardBrush" Color="#30465F" />
        <SolidColorBrush x:Key="InnerCardBrush" Color="#283B50" />
        <SolidColorBrush x:Key="InputBrush" Color="#344C66" />
        <SolidColorBrush x:Key="BorderBrush" Color="#506A86" />
        <SolidColorBrush x:Key="ContentTextBrush" Color="#F4F8FC" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#C1CDDA" />
        <SolidColorBrush x:Key="FadedTextBrush" Color="#98A8BA" />
        <SolidColorBrush x:Key="PrimaryRedBrush" Color="#E7252A" />
        <SolidColorBrush x:Key="PrimaryRedDarkBrush" Color="#C41F24" />
        <SolidColorBrush x:Key="SecondaryButtonBrush" Color="#36516E" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#4A617B" />

        <LinearGradientBrush x:Key="KpiBlueBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#3B82F6" Offset="0" />
            <GradientStop Color="#1D4ED8" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="KpiGreenBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#22C55E" Offset="0" />
            <GradientStop Color="#15803D" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="KpiRedBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#EF4444" Offset="0" />
            <GradientStop Color="#B91C1C" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="KpiOrangeBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F59E0B" Offset="0" />
            <GradientStop Color="#D97706" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryRedBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryRedBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="MinWidth" Value="150" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryRedDarkBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryRedDarkBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SecondaryButtonBrush}" />
            <Setter Property="Foreground" Value="{StaticResource ContentTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
            <Setter Property="Background" Value="#42617F" />
                    <Setter Property="BorderBrush" Value="#5E7894" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,16,16" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="SurfaceCardStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.12" Color="#000000" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource ContentTextBrush}" />
        </Style>

        <Style x:Key="SectionSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        </Style>

        <Style x:Key="FilterComboStyle" TargetType="ComboBox">
            <Setter Property="MinWidth" Value="170" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="10,0,0,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <LinearGradientBrush x:Key="ManagerPanelBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#30465F" Offset="0" />
            <GradientStop Color="#26384D" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="ManagerCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ManagerPanelBrush}" />
            <Setter Property="BorderBrush" Value="#4A617B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,12,12" />
        </Style>

        <Style x:Key="ManagerTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="ManagerMutedStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAB7C5" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="AdminDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#E5EDF5" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#4A617B" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2A3D53" />
            <Setter Property="Foreground" Value="#D8E2EC" />
            <Setter Property="BorderBrush" Value="#4A617B" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#E5EDF5" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <!-- Value Converters -->
        <converters:BoolToFolderIconConverter x:Key="BoolToFolderIcon"/>
        <converters:BoolToYesNoConverter x:Key="BoolToYesNo"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:FormTitleConverter x:Key="FormTitleConverter"/>
    </Application.Resources>
</Application>
