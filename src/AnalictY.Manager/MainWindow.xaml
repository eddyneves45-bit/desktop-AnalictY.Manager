<Window x:Class="AnalictY.Manager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:AnalictY.Manager.Views"
        mc:Ignorable="d"
        Title="AnalictY Manager"
        Height="760"
        MinHeight="650"
        Width="1280"
        MinWidth="1120"
        Background="#F3F5F7"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="SidebarBrush" Color="#111827" />
        <SolidColorBrush x:Key="SidebarPanelBrush" Color="#1F2937" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#F3F5F7" />
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="ContentTextBrush" Color="#18212B" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#64707D" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#DDE4EA" />
        <SolidColorBrush x:Key="LoginBgBrush" Color="#101820" />
        <SolidColorBrush x:Key="LoginPanelBrush" Color="#17212B" />
        <SolidColorBrush x:Key="LoginFieldBrush" Color="#162431" />
        <SolidColorBrush x:Key="LoginPrimaryTextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="LoginMutedTextBrush" Color="#AAB7C5" />
        <SolidColorBrush x:Key="LoginBorderBrush" Color="#334456" />
        <SolidColorBrush x:Key="PrimaryRedBrush" Color="#DC2626" />
        <SolidColorBrush x:Key="PrimaryRedDarkBrush" Color="#B91C1C" />
        <SolidColorBrush x:Key="RunningBrush" Color="#16A34A" />
        <SolidColorBrush x:Key="IdleBrush" Color="#F59E0B" />
        <SolidColorBrush x:Key="MaintenanceBrush" Color="#EF4444" />
        <SolidColorBrush x:Key="OfflineBrush" Color="#64748B" />

        <LinearGradientBrush x:Key="KpiBlueBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#3B82F6" Offset="0" />
            <GradientStop Color="#1D4ED8" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="KpiGreenBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#22C55E" Offset="0" />
            <GradientStop Color="#15803D" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="KpiRedBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#EF4444" Offset="0" />
            <GradientStop Color="#B91C1C" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="KpiOrangeBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F59E0B" Offset="0" />
            <GradientStop Color="#D97706" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource ContentTextBrush}" />
        </Style>

        <Style x:Key="SectionSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#E8EEF6" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Margin" Value="0,0,0,5" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1F3145" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryRedBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryRedBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="MinWidth" Value="150" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryRedDarkBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryRedDarkBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.65" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF2F7" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,16,16" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="SurfaceCardStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.08" Color="#000000" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="11,5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Background" Value="#F8FAFC" />
        </Style>

        <Style x:Key="StatusBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="FilterComboStyle" TargetType="ComboBox">
            <Setter Property="MinWidth" Value="170" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="10,0,0,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="InputPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid x:Name="LoginRoot">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Background" Value="{StaticResource LoginBgBrush}" />
                    </Style>
                </Grid.Style>

                <Grid.RowDefinitions>
                    <RowDefinition Height="48" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="42" />
                </Grid.RowDefinitions>

                <Border Background="#0B1220" BorderBrush="#17212B" BorderThickness="0,0,0,1">
                    <Grid Margin="20,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="24" Height="24" Background="#111827" BorderBrush="#2A3B4F" BorderThickness="1" CornerRadius="5">
                                <TextBlock Text="iT" Foreground="#EF4444" FontSize="11" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="AnalictY Server Manager" Foreground="#F8FAFC" FontSize="15" Margin="10,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="76,38">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="620" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center" Margin="0,0,52,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                            <Image Source="/Assets/industrial-intelligence-icon.png" Width="132" Height="132" />
                            <StackPanel Margin="18,24,0,0">
                                <TextBlock FontSize="43" FontWeight="Black">
                                    <Run Text="Analict" Foreground="{StaticResource LoginPrimaryTextBrush}" />
                                    <Run Text="Y" Foreground="#EF4444" />
                                </TextBlock>
                                <TextBlock Text="SERVER MANAGER" Foreground="#EF4444" FontSize="21" FontWeight="Bold" />
                            </StackPanel>
                        </StackPanel>

                        <Border Width="70" Height="3" Background="#EF4444" HorizontalAlignment="Left" Margin="10,0,0,24" />

                        <TextBlock Text="Administração e Monitoramento" Foreground="{StaticResource LoginPrimaryTextBrush}" FontSize="22" FontWeight="SemiBold" Margin="10,0,0,10" />
                        <TextBlock Text="da Plataforma Industrial" Foreground="{StaticResource LoginMutedTextBrush}" FontSize="21" Margin="10,0,0,30" />

                        <StackPanel Margin="10,0,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,26">
                                <Border Width="58" Height="58" Background="{StaticResource LoginPanelBrush}" BorderBrush="{StaticResource LoginBorderBrush}" BorderThickness="1" CornerRadius="8">
                                    <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" Foreground="#EF4444" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Margin="20,4,0,0">
                                    <TextBlock Text="Seguro" Foreground="{StaticResource LoginPrimaryTextBrush}" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Text="Acesso restrito para desenvolvimento" Foreground="{StaticResource LoginMutedTextBrush}" FontSize="15" Margin="0,8,0,0" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,26">
                                <Border Width="58" Height="58" Background="{StaticResource LoginPanelBrush}" BorderBrush="{StaticResource LoginBorderBrush}" BorderThickness="1" CornerRadius="8">
                                    <TextBlock Text="&#xE968;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource LoginPrimaryTextBrush}" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Margin="20,4,0,0">
                                    <TextBlock Text="Confiável" Foreground="{StaticResource LoginPrimaryTextBrush}" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Text="Monitoramento 24/7 da plataforma" Foreground="{StaticResource LoginMutedTextBrush}" FontSize="15" Margin="0,8,0,0" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <Border Width="58" Height="58" Background="{StaticResource LoginPanelBrush}" BorderBrush="{StaticResource LoginBorderBrush}" BorderThickness="1" CornerRadius="8">
                                    <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource LoginPrimaryTextBrush}" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Margin="20,4,0,0">
                                    <TextBlock Text="Inteligente" Foreground="{StaticResource LoginPrimaryTextBrush}" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Text="Informações em tempo real" Foreground="{StaticResource LoginMutedTextBrush}" FontSize="15" Margin="0,8,0,0" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1" Background="{StaticResource LoginPanelBrush}" BorderBrush="{StaticResource LoginBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="28" VerticalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="28" ShadowDepth="6" Opacity="0.22" Color="#000000" />
                        </Border.Effect>

                        <StackPanel>
                            <Grid Margin="0,0,0,22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Width="74" Height="74" Background="{StaticResource LoginFieldBrush}" BorderBrush="{StaticResource LoginBorderBrush}" BorderThickness="1" CornerRadius="37">
                                    <TextBlock Text="&#xE968;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource LoginPrimaryTextBrush}" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="20,8,0,0">
                                    <TextBlock Text="Conectar ao Servidor" Foreground="{StaticResource LoginPrimaryTextBrush}" FontSize="24" FontWeight="SemiBold" />
                                    <TextBlock Text="Informe as credenciais para acessar o AnalictY Server" Foreground="{StaticResource LoginMutedTextBrush}" FontSize="15" Margin="0,10,0,0" />
                                </StackPanel>
                                <Button Grid.Column="2" Content="{Binding ThemeButtonText}" Command="{Binding ToggleThemeCommand}" Style="{StaticResource SecondaryButtonStyle}" MinWidth="112" Padding="12,8" VerticalAlignment="Top" />
                            </Grid>

                            <Border Height="1" Background="{StaticResource LoginBorderBrush}" Margin="0,0,0,22" />

                            <TextBlock Text="Servidor" Foreground="{StaticResource LoginPrimaryTextBrush}" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBox Text="{Binding LoginServerUrl, UpdateSourceTrigger=PropertyChanged}" Background="{StaticResource LoginFieldBrush}" Foreground="{StaticResource LoginPrimaryTextBrush}" BorderBrush="{StaticResource LoginBorderBrush}" BorderThickness="1" Height="48" Padding="16,0" VerticalContentAlignment="Center" FontSize="16" />
                            <TextBlock Text="Exemplo: http://localhost:5000 ou http://192.168.1.100:5000" Foreground="{StaticResource LoginMutedTextBrush}" FontSize="12" Margin="0,9,0,18" />

                            <TextBlock Text="Usuário" Foreground="{StaticResource LoginPrimaryTextBrush}" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBox Text="{Binding LoginUsername, UpdateSourceTrigger=PropertyChanged}" Background="{StaticResource LoginFieldBrush}" Foreground="{StaticResource LoginPrimaryTextBrush}" BorderBrush="{StaticResource LoginBorderBrush}" BorderThickness="1" Height="48" Padding="16,0" VerticalContentAlignment="Center" FontSize="16" />

                            <TextBlock Text="Senha" Foreground="{StaticResource LoginPrimaryTextBrush}" FontWeight="SemiBold" Margin="0,18,0,8" />
                            <PasswordBox x:Name="LoginPasswordBox" PasswordChanged="LoginPasswordBox_OnPasswordChanged" Background="{StaticResource LoginFieldBrush}" Foreground="{StaticResource LoginPrimaryTextBrush}" BorderBrush="{StaticResource LoginBorderBrush}" BorderThickness="1" Height="48" Padding="16,0" VerticalContentAlignment="Center" FontSize="16" />

                            <CheckBox Content="Lembrar servidor e usuário" IsChecked="True" Foreground="{StaticResource LoginMutedTextBrush}" Margin="0,16,0,18" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1.25*" />
                                </Grid.ColumnDefinitions>
                                <Button Content="Testar Conexão" Command="{Binding CheckServerCommand}" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Stretch" Margin="0,0,18,0" />
                                <Button Grid.Column="1" Content="{Binding LoginButtonText}" Command="{Binding LoginCommand}" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Stretch" />
                            </Grid>

                            <TextBlock Text="{Binding LoginError}" Foreground="#FCA5A5" TextWrapping="Wrap" Margin="0,14,0,0" />

                            <Border Background="{StaticResource LoginFieldBrush}" BorderBrush="{StaticResource LoginBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,20,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="18" Height="18" Fill="#22C55E" Margin="0,0,12,0" />
                                        <TextBlock Text="Servidor encontrado" Foreground="#4ADE80" FontSize="16" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <UniformGrid Grid.Row="1" Columns="3" Margin="0,22,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Host" Foreground="{StaticResource LoginMutedTextBrush}" />
                                            <TextBlock Text="localhost" Foreground="{StaticResource LoginPrimaryTextBrush}" FontSize="16" Margin="0,8,0,0" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Versão" Foreground="{StaticResource LoginMutedTextBrush}" />
                                            <TextBlock Text="{Binding SystemVersion}" Foreground="{StaticResource LoginPrimaryTextBrush}" FontSize="16" Margin="0,8,0,0" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="API" Foreground="{StaticResource LoginMutedTextBrush}" />
                                            <TextBlock Text="{Binding ServerStatus}" Foreground="#4ADE80" FontSize="16" Margin="0,8,0,0" />
                                        </StackPanel>
                                    </UniformGrid>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="2" Background="#111827" BorderBrush="#203044" BorderThickness="0,1,0,0">
                    <Grid Margin="30,0">
                        <TextBlock Text="© 2026 AnalictY Industrial Intelligence" Foreground="#AAB7C5" VerticalAlignment="Center" />
                        <TextBlock Text="Versão: 0.1.6" Foreground="#AAB7C5" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="Documentação" Foreground="#AAB7C5" Margin="0,0,30,0" />
                            <TextBlock Text="Suporte" Foreground="#AAB7C5" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid x:Name="LoginModalOverlay" Visibility="Collapsed" />
            </Grid>
        </Grid>

        <Grid x:Name="ShellRoot">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="282" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
                <DockPanel Margin="12,14">
                    <StackPanel DockPanel.Dock="Top">
                        <Grid Margin="8,0,8,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Width="52"
                                    Height="52"
                                    Background="#111827"
                                    BorderBrush="#2A3B4F"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    VerticalAlignment="Center">
                                <TextBlock Text="iT"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#EF4444"
                                           FontSize="21"
                                           FontWeight="Black" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="iioT"
                                           Foreground="#F8FAFC"
                                           FontSize="22"
                                           FontWeight="Black" />
                                <TextBlock Text="AnalictY Manager"
                                           Foreground="#F87171"
                                           FontSize="13"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                            <TextBlock Grid.Column="2"
                                       Text="&#xE700;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Foreground="#CBD5E1"
                                       FontSize="20"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0" />
                        </Grid>

                        <Border Background="#17212B"
                                BorderBrush="#2B3B4F"
                                BorderThickness="1"
                                CornerRadius="2"
                                Padding="18"
                                Margin="8,0,8,18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Usuário"
                                           Foreground="#91A3B7"
                                           FontSize="13" />
                                <TextBlock Grid.Row="1"
                                           Text="{Binding AuthenticatedUserDisplay}"
                                           Foreground="#FFFFFF"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,10,0,2" />
                                <TextBlock Grid.Row="2"
                                           Text="{Binding AuthenticatedUserRole}"
                                           Foreground="#AAB7C5"
                                           FontSize="13"
                                           Margin="0,0,0,10" />
                                <StackPanel Grid.Row="3" Orientation="Horizontal">
                                    <Ellipse Width="11" Height="11" Margin="0,0,10,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#9AA8B8" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsServerOnline}" Value="True">
                                                        <Setter Property="Fill" Value="#72D44E" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="{Binding ServerStatus}"
                                               Foreground="#E8EEF6"
                                               FontSize="14" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <ItemsControl ItemsSource="{Binding NavigationItems}" Margin="8,0,8,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding PageKey}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Glyph}"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="21"
                                                       Width="34"
                                                       VerticalAlignment="Center"
                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="16"
                                                       VerticalAlignment="Center"
                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                        </StackPanel>
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PageKey}" Value="Exit">
                                                        <Setter Property="Background" Value="#DC2626" />
                                                        <Setter Property="Foreground" Value="White" />
                                                        <Setter Property="Margin" Value="0,18,0,0" />
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding PageKey}" Value="AdminDashboard" />
