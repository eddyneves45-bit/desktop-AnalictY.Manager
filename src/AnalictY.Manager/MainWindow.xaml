                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="0,0,16,0">
                                        <TextBlock Text="Máquina"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ContentTextBrush}"
                                                   Margin="0,0,0,8" />
                                        <ComboBox ItemsSource="{Binding DowntimeMachines}"
                                                  SelectedValue="{Binding SelectedDowntimeMachineId}"
                                                  SelectedValuePath="Id"
                                                  DisplayMemberPath="DisplayName"
                                                  Height="36"
                                                  VerticalContentAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                        <TextBlock Text="Período"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ContentTextBrush}"
                                                   Margin="0,0,0,8" />
                                        <ComboBox ItemsSource="{Binding DowntimePeriodOptions}"
                                                  SelectedItem="{Binding SelectedDowntimePeriod}"
                                                  Height="36"
                                                  VerticalContentAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                        <TextBlock Text="Consulta"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ContentTextBrush}"
                                                   Margin="0,0,0,8" />
                                        <Button Content="{Binding DowntimeHistoryButtonText}"
                                                Command="{Binding RefreshDowntimeHistoryCommand}"
                                                Style="{StaticResource PrimaryButtonStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <UniformGrid Columns="4">
                                <Border Style="{StaticResource CardBorderStyle}"
                                        Background="#2563EB"
                                        BorderThickness="0"
                                        Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="Total de paradas" Foreground="#EFF6FF" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding DowntimeTotalStopsText}" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,8,0,0" />
                                        <TextBlock Text="Eventos encontrados" Foreground="#DBEAFE" FontSize="12" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardBorderStyle}"
                                        Background="#DC2626"
                                        BorderThickness="0"
                                        Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="Tempo parado" Foreground="#FEE2E2" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding DowntimeTotalDuration}" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,8,0,0" />
                                        <TextBlock Text="Soma das durações" Foreground="#FEE2E2" FontSize="12" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardBorderStyle}"
                                        Background="#059669"
                                        BorderThickness="0"
                                        Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="Principal motivo" Foreground="#D1FAE5" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding DowntimeMainReason}" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,12,0,0" TextWrapping="Wrap" />
                                        <TextBlock Text="Motivo mais recorrente" Foreground="#D1FAE5" FontSize="12" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardBorderStyle}"
                                        Background="#334155"
                                        BorderThickness="0"
                                        Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="Período" Foreground="#E2E8F0" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding DowntimePeriodLabel}" Foreground="White" FontSize="25" FontWeight="Bold" Margin="0,12,0,0" />
                                        <TextBlock Text="Filtro selecionado" Foreground="#CBD5E1" FontSize="12" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <Border Style="{StaticResource CardBorderStyle}" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="Eventos de parada"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource ContentTextBrush}"
                                               Margin="0,0,0,14" />
                                    <DataGrid ItemsSource="{Binding DowntimeHistoryRows}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              RowHeaderWidth="0"
                                              MinHeight="260">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Início" Binding="{Binding Start}" Width="*" />
                                            <DataGridTextColumn Header="Fim" Binding="{Binding End}" Width="*" />
                                            <DataGridTextColumn Header="Motivo" Binding="{Binding Reason}" Width="1.4*" />
                                            <DataGridTextColumn Header="Categoria" Binding="{Binding Category}" Width="*" />
                                            <DataGridTextColumn Header="Duração" Binding="{Binding Duration}" Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="StatusPage">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="Status">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                        </Grid.Style>
                            <StackPanel>
                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Status do AnalictY"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ContentTextBrush}" />
                                        <TextBlock Text="{Binding StatusDataMessage}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="12"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="{Binding StatusButtonText}"
                                            Command="{Binding RefreshStatusCommand}"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource PrimaryButtonStyle}" />
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.1*" />
                                        <ColumnDefinition Width="0.9*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Style="{StaticResource CardBorderStyle}">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="72"
                                                        Height="72"
                                                        Background="#EEF3F5"
                                                        BorderBrush="#D9E2E8"
                                                        BorderThickness="1"
                                                        Margin="0,0,18,0">
                                                    <TextBlock Text="API"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontSize="18"
                                                               FontWeight="SemiBold"
                                                               Foreground="#1F7A5C" />
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="AnalictY Server"
                                                               FontSize="24"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource ContentTextBrush}" />
                                                    <TextBlock Text="{Binding ServerStatus}"
                                                               FontSize="32"
                                                               FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#7B8794" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsServerOnline}" Value="True">
                                                                        <Setter Property="Foreground" Value="#16815E" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding ServerStatusDetail}"
                                                               Foreground="{StaticResource MutedTextBrush}" />
                                                </StackPanel>
                                            </Grid>

                                            <UniformGrid Columns="2" Margin="0,22,0,0">
                                                <StackPanel Margin="0,0,18,14">
                                                    <TextBlock Text="Versão" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                                    <TextBlock Text="{Binding SystemVersion}" FontWeight="SemiBold" Foreground="{StaticResource ContentTextBrush}" />
                                                </StackPanel>
                                                <StackPanel Margin="0,0,0,14">
                                                    <TextBlock Text="Canal" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                                    <TextBlock Text="{Binding SystemChannel}" FontWeight="SemiBold" Foreground="{StaticResource ContentTextBrush}" />
                                                </StackPanel>
                                                <StackPanel Margin="0,0,18,0">
                                                    <TextBlock Text="Origem" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                                    <TextBlock Text="{Binding SystemSource}" FontWeight="SemiBold" Foreground="{StaticResource ContentTextBrush}" />
                                                </StackPanel>
                                                <StackPanel>
                                                    <TextBlock Text="Atualizado em" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                                    <TextBlock Text="{Binding CurrentServerTime}" FontWeight="SemiBold" Foreground="{StaticResource ContentTextBrush}" />
                                                </StackPanel>
                                            </UniformGrid>

                                            <Border Background="#F8FAFC"
                                                    BorderBrush="#DDE4EA"
                                                    BorderThickness="1"
                                                    Padding="12"
                                                    Margin="0,18,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="Pasta de dados"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               FontSize="12" />
                                                    <TextBlock Text="{Binding DataDirectory}"
                                                               TextWrapping="Wrap"
                                                               Foreground="{StaticResource ContentTextBrush}"
                                                               FontWeight="SemiBold" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="Conexão e runtime"
                                                       FontSize="20"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource ContentTextBrush}" />
                                            <Border Background="#F8FAFC"
                                                    BorderBrush="#DDE4EA"
                                                    BorderThickness="1"
                                                    Padding="14"
                                                    Margin="0,16,0,0">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Backend/API" Foreground="{StaticResource MutedTextBrush}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding ApiStatus}" FontWeight="SemiBold" Foreground="{StaticResource ContentTextBrush}" />
                                                    <TextBlock Grid.Row="1" Text="Banco" Foreground="{StaticResource MutedTextBrush}" Margin="0,12,0,0" />
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DatabaseStatus}" FontWeight="SemiBold" Foreground="{StaticResource ContentTextBrush}" Margin="0,12,0,0" />
                                                    <TextBlock Grid.Row="2" Text="Runtime" Foreground="{StaticResource MutedTextBrush}" Margin="0,12,0,0" />
                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding RuntimeStatus}" FontWeight="SemiBold" Foreground="{StaticResource ContentTextBrush}" Margin="0,12,0,0" />
                                                    <TextBlock Grid.Row="3" Text="Hora local" Foreground="{StaticResource MutedTextBrush}" Margin="0,12,0,0" />
                                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CurrentServerTime}" FontWeight="SemiBold" Foreground="{StaticResource ContentTextBrush}" Margin="0,12,0,0" />
                                                </Grid>
                                            </Border>
                                            <TextBlock Text="{Binding LastCheckedAt}"
                                                       Foreground="#8290A0"
                                                       FontSize="12"
                                                       Margin="0,14,0,0" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding StatusMetrics}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="4" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CardBorderStyle}"
                                                    Background="{Binding AccentBrush}"
                                                    BorderThickness="0"
                                                    Padding="18">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="#F8FAFC"
                                                               FontSize="13"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Value}"
                                                               Foreground="White"
                                                               FontSize="32"
                                                               FontWeight="Bold"
                                                               Margin="0,10,0,0" />
                                                    <TextBlock Text="{Binding Detail}"
                                                               Foreground="#E5E7EB"
                                                               FontSize="12"
                                                               Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Máquinas e status"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ContentTextBrush}"
                                           Margin="0,8,0,14" />
                                <ItemsControl ItemsSource="{Binding StatusMachines}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="286" Style="{StaticResource CardBorderStyle}">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="17"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource ContentTextBrush}" />
                                                        <Border Grid.Column="1"
                                                                Background="{Binding StatusBackground}"
                                                                Padding="8,4">
                                                            <TextBlock Text="{Binding Status}"
                                                                       Foreground="{Binding StatusBrush}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold" />
                                                        </Border>
                                                    </Grid>
                                                    <TextBlock Text="{Binding Area}"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               Margin="0,8,0,10" />
                                                    <TextBlock Text="{Binding CurrentOrder}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource ContentTextBrush}" />
                                                    <TextBlock Text="{Binding Efficiency, StringFormat='Eficiência: {0}'}"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               Margin="0,6,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>

                        <Grid x:Name="ReportPage">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="Report">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <StackPanel>
                                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <StackPanel Margin="0,0,18,0">
                                                <TextBlock Text="Tipo de relatório" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                                                <ComboBox Width="170" ItemsSource="{Binding ReportTypeOptions}" SelectedItem="{Binding SelectedReportType}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,18,0">
                                                <TextBlock Text="Máquina" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                                                        <ComboBox Width="220"
                                                          ItemsSource="{Binding ReportMachines}"
                                                          DisplayMemberPath="DisplayName"
                                                          SelectedValuePath="Id"
                                                          SelectedValue="{Binding SelectedReportMachineId}" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="Período" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                                                <ComboBox Width="160" ItemsSource="{Binding ReportPeriodOptions}" SelectedItem="{Binding SelectedReportPeriod}" />
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Prévia nativa" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource ContentTextBrush}" />
                                            <TextBlock Text="{Binding ReportMessage}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="{Binding ReportButtonText}" Command="{Binding RefreshReportCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,10,0" />
                                            <Button Content="CSV" IsEnabled="False" Padding="16,10" BorderBrush="#CBD5E1" Background="#F8FAFC" Foreground="#64748B" Margin="0,0,8,0" />
                                            <Button Content="PDF" IsEnabled="False" Padding="16,10" BorderBrush="#CBD5E1" Background="#F8FAFC" Foreground="#64748B" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <UniformGrid Columns="4">
                                    <Border Style="{StaticResource CardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Tipo" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                            <TextBlock Text="{Binding SelectedReportTypeLabel}" Foreground="{StaticResource ContentTextBrush}" FontSize="22" FontWeight="SemiBold" Margin="0,10,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource CardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Máquina" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                            <TextBlock Text="{Binding SelectedReportMachineLabel}" Foreground="{StaticResource ContentTextBrush}" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,10,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource CardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Período" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                            <TextBlock Text="{Binding SelectedReportPeriodLabel}" Foreground="{StaticResource ContentTextBrush}" FontSize="18" FontWeight="SemiBold" Margin="0,10,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource CardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Status" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                            <TextBlock Text="{Binding ReportStatusLabel}" Foreground="{StaticResource ContentTextBrush}" FontSize="18" FontWeight="SemiBold" Margin="0,10,0,0" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <Border Style="{StaticResource CardBorderStyle}" Margin="0">
                                    <StackPanel>
                                        <TextBlock Text="Prévia" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource ContentTextBrush}" Margin="0,0,0,12" />
                                        <DataGrid ItemsSource="{Binding ReportRows}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal" BorderThickness="0" RowHeaderWidth="0" MinHeight="260">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Hora" Binding="{Binding Hour}" Width="1*" />
                                                <DataGridTextColumn Header="Coluna A" Binding="{Binding ColumnA}" Width="1*" />
                                                <DataGridTextColumn Header="Coluna B" Binding="{Binding ColumnB}" Width="1*" />
                                                <DataGridTextColumn Header="Coluna C" Binding="{Binding ColumnC}" Width="1*" />
                                                <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="0.8*" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Grid x:Name="AlertsPage">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="Alerts">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <StackPanel>
                                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Central de alertas"
                                                       FontSize="22"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource ContentTextBrush}" />
                                            <TextBlock Text="{Binding AlertMessage}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,6,0,0" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="{Binding AlertButtonText}"
                                                Command="{Binding RefreshAlertsCommand}"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Margin="18,0,10,0"
                                                VerticalAlignment="Center" />
                                        <Button Grid.Column="2"
                                                Content="Testar Telegram"
                                                IsEnabled="False"
                                                Padding="16,10"
                                                BorderBrush="#CBD5E1"
                                                Background="#F8FAFC"
                                                Foreground="#64748B"
                                                VerticalAlignment="Center"
                                                ToolTip="Envio de teste será liberado em uma etapa futura com confirmação." />
                                    </Grid>
                                </Border>

                                <UniformGrid Columns="4">
                                    <Border Style="{StaticResource CardBorderStyle}" Background="#DC2626" BorderThickness="0">
                                        <StackPanel>
                                            <TextBlock Text="Alertas ativos" Foreground="#FEE2E2" FontSize="13" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding ActiveAlertCountText}" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,10,0,0" />
                                            <TextBlock Text="Pendentes de reconhecimento" Foreground="#FECACA" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource CardBorderStyle}" Background="#7F1D1D" BorderThickness="0">
                                        <StackPanel>
                                            <TextBlock Text="Críticos" Foreground="#FEE2E2" FontSize="13" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding CriticalAlertCountText}" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,10,0,0" />
                                            <TextBlock Text="Severidade alta ou crítica" Foreground="#FECACA" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource CardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Telegram" Foreground="{StaticResource MutedTextBrush}" FontSize="13" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding TelegramAlertStatus}" Foreground="{StaticResource ContentTextBrush}" FontSize="20" FontWeight="Bold" Margin="0,12,0,0" TextWrapping="Wrap" />
                                            <TextBlock Text="Status de envio configurado" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="Último envio/teste" Foreground="{StaticResource MutedTextBrush}" FontSize="13" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding LastAlertActivity}" Foreground="{StaticResource ContentTextBrush}" FontSize="18" FontWeight="Bold" Margin="0,12,0,0" TextWrapping="Wrap" />
                                            <TextBlock Text="Quando disponível pela API" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <Border Style="{StaticResource CardBorderStyle}" Margin="0">
                                    <StackPanel>
                                        <TextBlock Text="Regras e eventos"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ContentTextBrush}"
                                                   Margin="0,0,0,12" />
                                        <DataGrid ItemsSource="{Binding AlertRows}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  IsReadOnly="True"
                                                  HeadersVisibility="Column"
                                                  GridLinesVisibility="Horizontal"
                                                  BorderThickness="0"
                                                  RowHeaderWidth="0"
                                                  MinHeight="260">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="1.3*" />
                                                <DataGridTextColumn Header="Máquina/Escopo" Binding="{Binding Scope}" Width="*" />
                                                <DataGridTextColumn Header="Condição" Binding="{Binding Condition}" Width="1.7*" />
                                                <DataGridTextColumn Header="Severidade" Binding="{Binding Severity}" Width="0.8*" />
                                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="0.8*" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Grid x:Name="SettingsPage">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="Settings">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Frame NavigationUIVisibility="Hidden">
                                <Frame.Content>
                                    <views:ConfigPage/>
                                </Frame.Content>
                            </Frame>
                        </Grid>

                        <Grid x:Name="HelpPage">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="Help">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="340" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
                                    <StackPanel>
                                        <TextBlock Text="Manual do usuário"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ContentTextBrush}" />
                                        <TextBlock Text="Escolha um tópico para ler a orientação completa sobre o uso do console."
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   Margin="0,6,0,14" />
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="560">
                                            <ItemsControl ItemsSource="{Binding HelpTopics}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Command="{Binding DataContext.SelectHelpTopicCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Margin="0,0,0,10"
                                                                Padding="0"
                                                                BorderThickness="0"
                                                                Background="Transparent">
                                                            <Border Padding="14"
                                                                    Background="#F8FAFC"
                                                                    BorderBrush="#DDE4EA"
                                                                    BorderThickness="1">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Title}"
                                                                               FontSize="16"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{StaticResource ContentTextBrush}" />
                                                                    <TextBlock Text="{Binding Content}"
                                                                               TextWrapping="Wrap"
                                                                               Foreground="{StaticResource MutedTextBrush}"
                                                                               FontSize="13"
                                                                               Margin="0,6,0,0"
                                                                               MaxHeight="44" />
                                                                </StackPanel>
                                                            </Border>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Margin="0">
                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedHelpTitle}"
                                                   FontSize="24"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ContentTextBrush}" />
                                        <TextBlock Text="{Binding SelectedHelpContent}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="14"
                                                   Margin="0,10,0,0" />

                                        <Border Background="#F8FAFC"
                                                BorderBrush="#DDE4EA"
                                                BorderThickness="1"
                                                Padding="16"
                                                Margin="0,20,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Ação rápida"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontSize="12" />
                                                <TextBlock Text="{Binding SelectedHelpAction}"
                                                           Foreground="{StaticResource ContentTextBrush}"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Margin="0,8,0,0" />
                                            </StackPanel>
                                        </Border>

                                        <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                                            <Button Content="Abrir seção"
                                                    Command="{Binding OpenSelectedHelpCommand}"
                                                    IsEnabled="{Binding SelectedHelpCanOpen}"
                                                    Padding="16,10"
                                                    Background="#DC2626"
                                                    Foreground="White"
                                                    BorderBrush="#DC2626"
                                                    Margin="0,0,10,0" />
                                            <Button Content="Atualizar"
                                                    Command="{Binding NavigateCommand}"
                                                    CommandParameter="Help"
                                                    Visibility="Collapsed"
                                                    Padding="16,10"
                                                    BorderBrush="#CBD5E1"
                                                    Background="#F8FAFC"
                                                    Foreground="#64748B" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid x:Name="PlaceholderPage">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="Report">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Border Style="{StaticResource CardBorderStyle}" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="{Binding CurrentPageTitle}"
                                               FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource ContentTextBrush}" />
                                    <TextBlock Text="{Binding CurrentPageSubtitle}"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="14"
                                               Margin="0,10,0,0" />
                                    <Border Background="#F8FAFC"
                                            BorderBrush="#DDE4EA"
                                            BorderThickness="1"
                                            Padding="16"
                                            Margin="0,22,0,0">
                                        <TextBlock Text="O módulo de Relatórios depende do AnalictY Server. Certifique-se de que o servidor está em execução e que os endpoints de relatórios estão configurados."
                                                   TextWrapping="Wrap"
                                                   Foreground="#475569" />
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
