<Window x:Class="AnalictY.Console.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AnalictY Console"
        Height="640"
        MinHeight="560"
        Width="1040"
        MinWidth="920"
        Background="#F3F6F8"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="SidebarBrush" Color="#141A22" />
        <SolidColorBrush x:Key="ContentTextBrush" Color="#18212B" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#64707D" />

        <Style x:Key="SidebarItemTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D7DEE7" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1F7A5C" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#1F7A5C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="MinWidth" Value="150" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.65" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel Margin="24,28">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="AnalictY"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Console"
                               Foreground="#8EA0B5"
                               FontSize="14"
                               Margin="0,2,0,38" />

                    <Border Background="#202A35"
                            BorderBrush="#2D3946"
                            BorderThickness="1"
                            Padding="14,12"
                            Margin="0,0,0,28">
                        <StackPanel>
                            <TextBlock Text="Servidor local"
                                       Foreground="#8EA0B5"
                                       FontSize="12" />
                            <TextBlock Text="{Binding ServerStatus}"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Visão Geral" Style="{StaticResource SidebarItemTextStyle}" />
                    <TextBlock Text="Status" Style="{StaticResource SidebarItemTextStyle}" />
                    <TextBlock Text="Histórico Produção" Style="{StaticResource SidebarItemTextStyle}" />
                    <TextBlock Text="Histórico Paradas" Style="{StaticResource SidebarItemTextStyle}" />
                    <TextBlock Text="Relatório" Style="{StaticResource SidebarItemTextStyle}" />
                    <TextBlock Text="Alertas" Style="{StaticResource SidebarItemTextStyle}" />
                    <TextBlock Text="Configurações" Style="{StaticResource SidebarItemTextStyle}" />
                </StackPanel>

                <TextBlock DockPanel.Dock="Bottom"
                           Text="Etapa inicial"
                           Foreground="#6E7F92"
                           FontSize="12" />
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="72" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="White"
                    BorderBrush="#DDE4EA"
                    BorderThickness="0,0,0,1">
                <Grid Margin="32,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="AnalictY Console"
                               VerticalAlignment="Center"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ContentTextBrush}" />

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#A3ADB8" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsServerOnline}" Value="True">
                                            <Setter Property="Fill" Value="#20B486" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding ServerStatus}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="32">
                <Border Background="White"
                        BorderBrush="#DDE4EA"
                        BorderThickness="1"
                        Padding="28">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="AnalictY Server"
                                       Foreground="{StaticResource ContentTextBrush}"
                                       FontSize="26"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Status da API local utilizada pelo cliente desktop."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="14"
                                       Margin="0,8,0,0" />
                        </StackPanel>

                        <Grid Grid.Row="1" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Width="76"
                                    Height="76"
                                    Background="#EEF3F5"
                                    BorderBrush="#D9E2E8"
                                    BorderThickness="1"
                                    Margin="0,0,22,0">
                                <TextBlock Text="API"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="#1F7A5C" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding ServerStatus}"
                                           FontSize="34"
                                           FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#7B8794" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsServerOnline}" Value="True">
                                                    <Setter Property="Foreground" Value="#16815E" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding ServerStatusDetail}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="14"
                                           Margin="0,8,0,0" />
                                <TextBlock Text="{Binding LastCheckedAt}"
                                           Foreground="#8290A0"
                                           FontSize="12"
                                           Margin="0,10,0,0" />
                            </StackPanel>
                        </Grid>

                        <Button Grid.Row="2"
                                Content="{Binding CheckButtonText}"
                                Command="{Binding CheckServerCommand}"
                                HorizontalAlignment="Left"
                                Style="{StaticResource PrimaryButtonStyle}" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
