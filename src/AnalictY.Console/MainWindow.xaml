<Window x:Class="AnalictY.Console.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AnalictY Console"
        Height="760"
        MinHeight="650"
        Width="1220"
        MinWidth="1080"
        Background="#F4F6F8"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="SidebarBrush" Color="#111827" />
        <SolidColorBrush x:Key="SidebarPanelBrush" Color="#1F2937" />
        <SolidColorBrush x:Key="ContentTextBrush" Color="#18212B" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#64707D" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#DDE4EA" />

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#D7DEE7" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#263244" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#DC2626" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#DC2626" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="MinWidth" Value="150" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.65" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,16,16" />
        </Style>

        <Style x:Key="FilterComboStyle" TargetType="ComboBox">
            <Setter Property="MinWidth" Value="160" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="InputPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid x:Name="LoginRoot">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="0.95*" />
            </Grid.ColumnDefinitions>

            <Border Background="#0F172A">
                <Grid Margin="58">
                    <StackPanel VerticalAlignment="Center">
                        <Border Width="58"
                                Height="58"
                                Background="#111827"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                HorizontalAlignment="Left">
                            <TextBlock Text="iT"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#EF4444"
                                       FontSize="24"
                                       FontWeight="Black" />
                        </Border>
                        <TextBlock Text="iioT AnalictY Console"
                                   Foreground="White"
                                   FontSize="34"
                                   FontWeight="Black"
                                   Margin="0,26,0,0" />
                        <TextBlock Text="Cliente desktop nativo para acompanhar o AnalictY Server instalado neste Windows."
                                   Foreground="#CBD5E1"
                                   FontSize="16"
                                   TextWrapping="Wrap"
                                   Width="470"
                                   Margin="0,14,0,0" />
                        <Border Background="#182235"
                                BorderBrush="#2D3A4F"
                                BorderThickness="1"
                                Padding="18"
                                Width="470"
                                HorizontalAlignment="Left"
                                Margin="0,34,0,0">
                            <StackPanel>
                                <TextBlock Text="Sem navegador embutido"
                                           Foreground="#F8FAFC"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="A autenticação usa a API local do AnalictY Server e mantém a sessão somente em memória."
                                           Foreground="#94A3B8"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Background="#F4F6F8">
                <Border Width="420"
                        Background="White"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        Padding="34"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Entrar"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ContentTextBrush}" />
                        <TextBlock Text="Use o mesmo acesso do AnalictY Server."
                                   FontSize="14"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,8,0,28" />

                        <TextBlock Text="Usuário ou e-mail"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ContentTextBrush}"
                                   Margin="0,0,0,8" />
                        <TextBox Text="{Binding LoginUsername, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputTextBoxStyle}" />

                        <TextBlock Text="Senha"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ContentTextBrush}"
                                   Margin="0,18,0,8" />
                        <PasswordBox x:Name="LoginPasswordBox"
                                     PasswordChanged="LoginPasswordBox_OnPasswordChanged"
                                     Style="{StaticResource InputPasswordBoxStyle}" />

                        <TextBlock Text="{Binding LoginError}"
                                   Foreground="#B91C1C"
                                   TextWrapping="Wrap"
                                   Margin="0,14,0,0" />

                        <Button Content="{Binding LoginButtonText}"
                                Command="{Binding LoginCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Margin="0,22,0,0" />

                        <TextBlock Text="Recuperação de senha será disponibilizada em uma próxima etapa."
                                   Foreground="#94A3B8"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,18,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Grid x:Name="ShellRoot">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="262" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
                <DockPanel Margin="22,24">
                    <StackPanel DockPanel.Dock="Top">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                            <Border Width="42"
                                    Height="42"
                                    Background="#0F172A"
                                    BorderBrush="#273244"
                                    BorderThickness="1"
                                    VerticalAlignment="Center">
                                <TextBlock Text="iT"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#EF4444"
                                           FontSize="18"
                                           FontWeight="Black" />
                            </Border>
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="iioT"
                                           Foreground="White"
                                           FontSize="23"
                                           FontWeight="Black" />
                                <TextBlock Text="AnalictY Console"
                                           Foreground="#F87171"
                                           FontSize="13" />
                            </StackPanel>
                        </StackPanel>

                        <Border Background="{StaticResource SidebarPanelBrush}"
                                BorderBrush="#2D3946"
                                BorderThickness="1"
                                Padding="14"
                                Margin="0,0,0,20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Usuário"
                                           Foreground="#8EA0B5"
                                           FontSize="12" />
                                <TextBlock Grid.Row="1"
                                           Text="{Binding AuthenticatedUserDisplay}"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Margin="0,3,0,2" />
                                <TextBlock Grid.Row="2"
                                           Text="{Binding AuthenticatedUserRole}"
                                           Foreground="#9CA8B8"
                                           FontSize="12"
                                           Margin="0,0,0,10" />
                                <StackPanel Grid.Row="3" Orientation="Horizontal">
                                    <Ellipse Width="9" Height="9" Margin="0,0,8,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#9CA3AF" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsServerOnline}" Value="True">
                                                        <Setter Property="Fill" Value="#20B486" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="{Binding ServerStatus}"
                                               Foreground="#D7DEE7"
                                               FontSize="12" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <ItemsControl ItemsSource="{Binding NavigationItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Title}"
                                            Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding PageKey}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PageKey}" Value="Exit">
                                                        <Setter Property="Background" Value="#DC2626" />
                                                        <Setter Property="Foreground" Value="White" />
                                                        <Setter Property="Margin" Value="0,18,0,0" />
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <TextBlock DockPanel.Dock="Bottom"
                               Text="Cliente nativo Windows"
                               Foreground="#6E7F92"
                               FontSize="12" />
                </DockPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="78" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="White"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="0,0,0,1">
                    <Grid Margin="30,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentPageTitle}"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ContentTextBrush}" />
                            <TextBlock Text="{Binding CurrentPageSubtitle}"
                                       FontSize="13"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="AnalictY Console"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,18,0" />
                            <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#A3ADB8" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsServerOnline}" Value="True">
                                                <Setter Property="Fill" Value="#20B486" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding ServerStatus}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <Grid Margin="30">
                        <Grid x:Name="OverviewPage">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="Overview">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <StackPanel>
                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Resumo operacional"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ContentTextBrush}" />
                                        <TextBlock Text="{Binding OverviewDataMessage}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <ComboBox ItemsSource="{Binding ShiftFilters}"
                                                  SelectedItem="{Binding SelectedShift}"
                                                  Style="{StaticResource FilterComboStyle}" />
                                        <ComboBox ItemsSource="{Binding LineFilters}"
                                                  SelectedItem="{Binding SelectedLine}"
                                                  Style="{StaticResource FilterComboStyle}" />
                                    </StackPanel>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding Kpis}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="4" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CardBorderStyle}"
                                                    Background="{Binding AccentBrush}"
                                                    BorderThickness="0"
                                                    Padding="20">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="#F8FAFC" />
                                                    <TextBlock Grid.Row="1"
                                                               Text="{Binding Value}"
                                                               FontSize="38"
                                                               FontWeight="Bold"
                                                               Foreground="White"
                                                               Margin="0,12,0,0" />
                                                    <TextBlock Grid.Row="2"
                                                               Text="{Binding Detail}"
                                                               FontSize="12"
                                                               Foreground="#E5E7EB"
                                                               Margin="0,2,0,0" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Máquinas"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ContentTextBrush}"
                                           Margin="0,8,0,14" />

                                <ItemsControl ItemsSource="{Binding Machines}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="286" Style="{StaticResource CardBorderStyle}">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="18"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource ContentTextBrush}" />
                                                        <Border Grid.Column="1"
                                                                Background="{Binding StatusBackground}"
                                                                Padding="8,4">
                                                            <TextBlock Text="{Binding Status}"
                                                                       Foreground="{Binding StatusBrush}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold" />
                                                        </Border>
                                                    </Grid>
                                                    <TextBlock Text="{Binding Area}"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               Margin="0,8,0,14" />
                                                    <TextBlock Text="{Binding CurrentOrder}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource ContentTextBrush}" />
                                                    <TextBlock Text="{Binding Efficiency, StringFormat='Eficiência: {0}'}"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               Margin="0,6,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="ProductionHistoryPage">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="ProductionHistory">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <StackPanel>
                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Histórico de Produção"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource ContentTextBrush}" />
                                    <TextBlock Text="{Binding ProductionHistoryMessage}"
                                               FontSize="12"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="{Binding ProductionHistoryButtonText}"
                                        Command="{Binding RefreshProductionHistoryCommand}"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource PrimaryButtonStyle}" />
                            </Grid>

                            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,18">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="1.1*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="0,0,16,0">
                                        <TextBlock Text="Máquina"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ContentTextBrush}"
                                                   Margin="0,0,0,8" />
                                        <ComboBox ItemsSource="{Binding ProductionMachines}"
                                                  SelectedValue="{Binding SelectedProductionMachineId}"
                                                  SelectedValuePath="Id"
                                                  DisplayMemberPath="DisplayName"
                                                  Height="36"
                                                  VerticalContentAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                        <TextBlock Text="Período"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ContentTextBrush}"
                                                   Margin="0,0,0,8" />
                                        <ComboBox ItemsSource="{Binding ProductionPeriodOptions}"
                                                  SelectedItem="{Binding SelectedProductionPeriod}"
                                                  Height="36"
                                                  VerticalContentAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                        <TextBlock Text="Consulta"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ContentTextBrush}"
                                                   Margin="0,0,0,8" />
                                        <Button Content="{Binding ProductionHistoryButtonText}"
                                                Command="{Binding RefreshProductionHistoryCommand}"
                                                Style="{StaticResource PrimaryButtonStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <UniformGrid Columns="4">
                                <Border Style="{StaticResource CardBorderStyle}"
                                        Background="#2563EB"
                                        BorderThickness="0"
                                        Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="Total produzido" Foreground="#EFF6FF" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ProductionTotalProducedText}" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,8,0,0" />
                                        <TextBlock Text="{Binding ProductionMachineName}" Foreground="#DBEAFE" FontSize="12" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardBorderStyle}"
                                        Background="#DC2626"
                                        BorderThickness="0"
                                        Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="Quantidade perdida" Foreground="#FEE2E2" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ProductionTotalLostText}" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,8,0,0" />
                                        <TextBlock Text="Perdas do período" Foreground="#FEE2E2" FontSize="12" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardBorderStyle}"
                                        Background="#059669"
                                        BorderThickness="0"
                                        Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="Quantidade boa" Foreground="#D1FAE5" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ProductionTotalGoodText}" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,8,0,0" />
                                        <TextBlock Text="Produzido menos perdas" Foreground="#D1FAE5" FontSize="12" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardBorderStyle}"
                                        Background="#334155"
                                        BorderThickness="0"
                                        Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="Período" Foreground="#E2E8F0" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ProductionPeriodLabel}" Foreground="White" FontSize="25" FontWeight="Bold" Margin="0,12,0,0" />
                                        <TextBlock Text="Filtro selecionado" Foreground="#CBD5E1" FontSize="12" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <Border Style="{StaticResource CardBorderStyle}" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="Produção por hora"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource ContentTextBrush}"
                                               Margin="0,0,0,14" />
                                    <DataGrid ItemsSource="{Binding ProductionHistoryRows}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              RowHeaderWidth="0"
                                              MinHeight="260">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Hora" Binding="{Binding Hour}" Width="*" />
                                            <DataGridTextColumn Header="Produzido" Binding="{Binding Produced, StringFormat=N0}" Width="*" />
                                            <DataGridTextColumn Header="Perdido" Binding="{Binding Lost, StringFormat=N0}" Width="*" />
                                            <DataGridTextColumn Header="Bom" Binding="{Binding Good, StringFormat=N0}" Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="DowntimeHistoryPage">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="DowntimeHistory">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <StackPanel>
                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Histórico de Paradas"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource ContentTextBrush}" />
                                    <TextBlock Text="{Binding DowntimeHistoryMessage}"
                                               FontSize="12"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="{Binding DowntimeHistoryButtonText}"
                                        Command="{Binding RefreshDowntimeHistoryCommand}"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource PrimaryButtonStyle}" />
                            </Grid>

                            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,18">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="1.1*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="0,0,16,0">
                                        <TextBlock Text="Máquina"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ContentTextBrush}"
                                                   Margin="0,0,0,8" />
                                        <ComboBox ItemsSource="{Binding DowntimeMachines}"
                                                  SelectedValue="{Binding SelectedDowntimeMachineId}"
                                                  SelectedValuePath="Id"
                                                  DisplayMemberPath="DisplayName"
                                                  Height="36"
                                                  VerticalContentAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                        <TextBlock Text="Período"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ContentTextBrush}"
                                                   Margin="0,0,0,8" />
                                        <ComboBox ItemsSource="{Binding DowntimePeriodOptions}"
                                                  SelectedItem="{Binding SelectedDowntimePeriod}"
                                                  Height="36"
                                                  VerticalContentAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                        <TextBlock Text="Consulta"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ContentTextBrush}"
                                                   Margin="0,0,0,8" />
                                        <Button Content="{Binding DowntimeHistoryButtonText}"
                                                Command="{Binding RefreshDowntimeHistoryCommand}"
                                                Style="{StaticResource PrimaryButtonStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <UniformGrid Columns="4">
                                <Border Style="{StaticResource CardBorderStyle}"
                                        Background="#2563EB"
                                        BorderThickness="0"
                                        Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="Total de paradas" Foreground="#EFF6FF" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding DowntimeTotalStopsText}" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,8,0,0" />
                                        <TextBlock Text="Eventos encontrados" Foreground="#DBEAFE" FontSize="12" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardBorderStyle}"
                                        Background="#DC2626"
                                        BorderThickness="0"
                                        Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="Tempo parado" Foreground="#FEE2E2" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding DowntimeTotalDuration}" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,8,0,0" />
                                        <TextBlock Text="Soma das durações" Foreground="#FEE2E2" FontSize="12" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardBorderStyle}"
                                        Background="#059669"
                                        BorderThickness="0"
                                        Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="Principal motivo" Foreground="#D1FAE5" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding DowntimeMainReason}" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,12,0,0" TextWrapping="Wrap" />
                                        <TextBlock Text="Motivo mais recorrente" Foreground="#D1FAE5" FontSize="12" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardBorderStyle}"
                                        Background="#334155"
                                        BorderThickness="0"
                                        Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="Período" Foreground="#E2E8F0" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding DowntimePeriodLabel}" Foreground="White" FontSize="25" FontWeight="Bold" Margin="0,12,0,0" />
                                        <TextBlock Text="Filtro selecionado" Foreground="#CBD5E1" FontSize="12" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <Border Style="{StaticResource CardBorderStyle}" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="Eventos de parada"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource ContentTextBrush}"
                                               Margin="0,0,0,14" />
                                    <DataGrid ItemsSource="{Binding DowntimeHistoryRows}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              RowHeaderWidth="0"
                                              MinHeight="260">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Início" Binding="{Binding Start}" Width="*" />
                                            <DataGridTextColumn Header="Fim" Binding="{Binding End}" Width="*" />
                                            <DataGridTextColumn Header="Motivo" Binding="{Binding Reason}" Width="1.4*" />
                                            <DataGridTextColumn Header="Categoria" Binding="{Binding Category}" Width="*" />
                                            <DataGridTextColumn Header="Duração" Binding="{Binding Duration}" Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="StatusPage">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="Status">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                        </Grid.Style>
                            <StackPanel>
                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Status do AnalictY"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ContentTextBrush}" />
                                        <TextBlock Text="{Binding StatusDataMessage}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="12"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="{Binding StatusButtonText}"
                                            Command="{Binding RefreshStatusCommand}"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource PrimaryButtonStyle}" />
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.1*" />
                                        <ColumnDefinition Width="0.9*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Style="{StaticResource CardBorderStyle}">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="72"
                                                        Height="72"
                                                        Background="#EEF3F5"
                                                        BorderBrush="#D9E2E8"
                                                        BorderThickness="1"
                                                        Margin="0,0,18,0">
                                                    <TextBlock Text="API"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontSize="18"
                                                               FontWeight="SemiBold"
                                                               Foreground="#1F7A5C" />
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="AnalictY Server"
                                                               FontSize="24"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource ContentTextBrush}" />
                                                    <TextBlock Text="{Binding ServerStatus}"
                                                               FontSize="32"
                                                               FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#7B8794" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsServerOnline}" Value="True">
                                                                        <Setter Property="Foreground" Value="#16815E" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding ServerStatusDetail}"
                                                               Foreground="{StaticResource MutedTextBrush}" />
                                                </StackPanel>
                                            </Grid>

                                            <UniformGrid Columns="2" Margin="0,22,0,0">
                                                <StackPanel Margin="0,0,18,14">
                                                    <TextBlock Text="Versão" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                                    <TextBlock Text="{Binding SystemVersion}" FontWeight="SemiBold" Foreground="{StaticResource ContentTextBrush}" />
                                                </StackPanel>
                                                <StackPanel Margin="0,0,0,14">
                                                    <TextBlock Text="Canal" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                                    <TextBlock Text="{Binding SystemChannel}" FontWeight="SemiBold" Foreground="{StaticResource ContentTextBrush}" />
                                                </StackPanel>
                                                <StackPanel Margin="0,0,18,0">
                                                    <TextBlock Text="Origem" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                                    <TextBlock Text="{Binding SystemSource}" FontWeight="SemiBold" Foreground="{StaticResource ContentTextBrush}" />
                                                </StackPanel>
                                                <StackPanel>
                                                    <TextBlock Text="Atualizado em" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                                    <TextBlock Text="{Binding CurrentServerTime}" FontWeight="SemiBold" Foreground="{StaticResource ContentTextBrush}" />
                                                </StackPanel>
                                            </UniformGrid>

                                            <Border Background="#F8FAFC"
                                                    BorderBrush="#DDE4EA"
                                                    BorderThickness="1"
                                                    Padding="12"
                                                    Margin="0,18,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="Pasta de dados"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               FontSize="12" />
                                                    <TextBlock Text="{Binding DataDirectory}"
                                                               TextWrapping="Wrap"
                                                               Foreground="{StaticResource ContentTextBrush}"
                                                               FontWeight="SemiBold" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="Conexão e runtime"
                                                       FontSize="20"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource ContentTextBrush}" />
                                            <Border Background="#F8FAFC"
                                                    BorderBrush="#DDE4EA"
                                                    BorderThickness="1"
                                                    Padding="14"
                                                    Margin="0,16,0,0">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Backend/API" Foreground="{StaticResource MutedTextBrush}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding ApiStatus}" FontWeight="SemiBold" Foreground="{StaticResource ContentTextBrush}" />
                                                    <TextBlock Grid.Row="1" Text="Banco" Foreground="{StaticResource MutedTextBrush}" Margin="0,12,0,0" />
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DatabaseStatus}" FontWeight="SemiBold" Foreground="{StaticResource ContentTextBrush}" Margin="0,12,0,0" />
                                                    <TextBlock Grid.Row="2" Text="Runtime" Foreground="{StaticResource MutedTextBrush}" Margin="0,12,0,0" />
                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding RuntimeStatus}" FontWeight="SemiBold" Foreground="{StaticResource ContentTextBrush}" Margin="0,12,0,0" />
                                                    <TextBlock Grid.Row="3" Text="Hora local" Foreground="{StaticResource MutedTextBrush}" Margin="0,12,0,0" />
                                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CurrentServerTime}" FontWeight="SemiBold" Foreground="{StaticResource ContentTextBrush}" Margin="0,12,0,0" />
                                                </Grid>
                                            </Border>
                                            <TextBlock Text="{Binding LastCheckedAt}"
                                                       Foreground="#8290A0"
                                                       FontSize="12"
                                                       Margin="0,14,0,0" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding StatusMetrics}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="4" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CardBorderStyle}"
                                                    Background="{Binding AccentBrush}"
                                                    BorderThickness="0"
                                                    Padding="18">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="#F8FAFC"
                                                               FontSize="13"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Value}"
                                                               Foreground="White"
                                                               FontSize="32"
                                                               FontWeight="Bold"
                                                               Margin="0,10,0,0" />
                                                    <TextBlock Text="{Binding Detail}"
                                                               Foreground="#E5E7EB"
                                                               FontSize="12"
                                                               Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Máquinas e status"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ContentTextBrush}"
                                           Margin="0,8,0,14" />
                                <ItemsControl ItemsSource="{Binding StatusMachines}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="286" Style="{StaticResource CardBorderStyle}">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="17"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource ContentTextBrush}" />
                                                        <Border Grid.Column="1"
                                                                Background="{Binding StatusBackground}"
                                                                Padding="8,4">
                                                            <TextBlock Text="{Binding Status}"
                                                                       Foreground="{Binding StatusBrush}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold" />
                                                        </Border>
                                                    </Grid>
                                                    <TextBlock Text="{Binding Area}"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               Margin="0,8,0,10" />
                                                    <TextBlock Text="{Binding CurrentOrder}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource ContentTextBrush}" />
                                                    <TextBlock Text="{Binding Efficiency, StringFormat='Eficiência: {0}'}"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               Margin="0,6,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>

                        <Grid x:Name="AlertsPage">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="Alerts">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <StackPanel>
                                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Central de alertas"
                                                       FontSize="22"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource ContentTextBrush}" />
                                            <TextBlock Text="{Binding AlertMessage}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,6,0,0" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="{Binding AlertButtonText}"
                                                Command="{Binding RefreshAlertsCommand}"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Margin="18,0,10,0"
                                                VerticalAlignment="Center" />
                                        <Button Grid.Column="2"
                                                Content="Testar Telegram"
                                                IsEnabled="False"
                                                Padding="16,10"
                                                BorderBrush="#CBD5E1"
                                                Background="#F8FAFC"
                                                Foreground="#64748B"
                                                VerticalAlignment="Center"
                                                ToolTip="Envio de teste será liberado em uma etapa futura com confirmação." />
                                    </Grid>
                                </Border>

                                <UniformGrid Columns="4">
                                    <Border Style="{StaticResource CardBorderStyle}" Background="#DC2626" BorderThickness="0">
                                        <StackPanel>
                                            <TextBlock Text="Alertas ativos" Foreground="#FEE2E2" FontSize="13" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding ActiveAlertCountText}" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,10,0,0" />
                                            <TextBlock Text="Pendentes de reconhecimento" Foreground="#FECACA" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource CardBorderStyle}" Background="#7F1D1D" BorderThickness="0">
                                        <StackPanel>
                                            <TextBlock Text="Críticos" Foreground="#FEE2E2" FontSize="13" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding CriticalAlertCountText}" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,10,0,0" />
                                            <TextBlock Text="Severidade alta ou crítica" Foreground="#FECACA" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource CardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Telegram" Foreground="{StaticResource MutedTextBrush}" FontSize="13" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding TelegramAlertStatus}" Foreground="{StaticResource ContentTextBrush}" FontSize="20" FontWeight="Bold" Margin="0,12,0,0" TextWrapping="Wrap" />
                                            <TextBlock Text="Status de envio configurado" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="Último envio/teste" Foreground="{StaticResource MutedTextBrush}" FontSize="13" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding LastAlertActivity}" Foreground="{StaticResource ContentTextBrush}" FontSize="18" FontWeight="Bold" Margin="0,12,0,0" TextWrapping="Wrap" />
                                            <TextBlock Text="Quando disponível pela API" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <Border Style="{StaticResource CardBorderStyle}" Margin="0">
                                    <StackPanel>
                                        <TextBlock Text="Regras e eventos"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ContentTextBrush}"
                                                   Margin="0,0,0,12" />
                                        <DataGrid ItemsSource="{Binding AlertRows}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  IsReadOnly="True"
                                                  HeadersVisibility="Column"
                                                  GridLinesVisibility="Horizontal"
                                                  BorderThickness="0"
                                                  RowHeaderWidth="0"
                                                  MinHeight="260">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="1.3*" />
                                                <DataGridTextColumn Header="Máquina/Escopo" Binding="{Binding Scope}" Width="*" />
                                                <DataGridTextColumn Header="Condição" Binding="{Binding Condition}" Width="1.7*" />
                                                <DataGridTextColumn Header="Severidade" Binding="{Binding Severity}" Width="0.8*" />
                                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="0.8*" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Grid x:Name="SettingsPage">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="Settings">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <ItemsControl ItemsSource="{Binding ModuleCards}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="292" Style="{StaticResource CardBorderStyle}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource ContentTextBrush}" />
                                                <TextBlock Text="{Binding Description}"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           Margin="0,8,0,18" />
                                                <Border Background="#EEF3F5"
                                                        BorderBrush="#DDE4EA"
                                                        BorderThickness="1"
                                                        Padding="8,5"
                                                        HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding State}"
                                                               Foreground="#475569"
                                                               FontSize="12"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <Grid x:Name="HelpPage">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="Help">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <ItemsControl ItemsSource="{Binding HelpTopics}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,14">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource ContentTextBrush}" />
                                                <TextBlock Text="{Binding Content}"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontSize="14"
                                                           Margin="0,8,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <Grid x:Name="PlaceholderPage">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="Report">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Border Style="{StaticResource CardBorderStyle}" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="{Binding CurrentPageTitle}"
                                               FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource ContentTextBrush}" />
                                    <TextBlock Text="{Binding CurrentPageSubtitle}"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="14"
                                               Margin="0,10,0,0" />
                                    <Border Background="#F8FAFC"
                                            BorderBrush="#DDE4EA"
                                            BorderThickness="1"
                                            Padding="16"
                                            Margin="0,22,0,0">
                                        <TextBlock Text="Conteúdo nativo reservado para a próxima etapa. Nenhuma API, banco ou atualização real foi implementada aqui."
                                                   TextWrapping="Wrap"
                                                   Foreground="#475569" />
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
