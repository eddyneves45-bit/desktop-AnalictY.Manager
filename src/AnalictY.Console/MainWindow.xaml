<Window x:Class="AnalictY.Console.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AnalictY Console"
        Height="760"
        MinHeight="650"
        Width="1280"
        MinWidth="1120"
        Background="#F3F5F7"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="SidebarBrush" Color="#111827" />
        <SolidColorBrush x:Key="SidebarPanelBrush" Color="#1F2937" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#F3F5F7" />
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="ContentTextBrush" Color="#18212B" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#64707D" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#DDE4EA" />
        <SolidColorBrush x:Key="PrimaryRedBrush" Color="#DC2626" />
        <SolidColorBrush x:Key="PrimaryRedDarkBrush" Color="#B91C1C" />
        <SolidColorBrush x:Key="RunningBrush" Color="#16A34A" />
        <SolidColorBrush x:Key="IdleBrush" Color="#F59E0B" />
        <SolidColorBrush x:Key="MaintenanceBrush" Color="#EF4444" />
        <SolidColorBrush x:Key="OfflineBrush" Color="#64748B" />

        <LinearGradientBrush x:Key="KpiBlueBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#3B82F6" Offset="0" />
            <GradientStop Color="#1D4ED8" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="KpiGreenBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#22C55E" Offset="0" />
            <GradientStop Color="#15803D" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="KpiRedBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#EF4444" Offset="0" />
            <GradientStop Color="#B91C1C" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="KpiOrangeBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F59E0B" Offset="0" />
            <GradientStop Color="#D97706" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource ContentTextBrush}" />
        </Style>

        <Style x:Key="SectionSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#D7DEE7" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="14,11" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#243041" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryRedBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryRedBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="MinWidth" Value="150" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryRedDarkBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryRedDarkBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.65" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF2F7" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,16,16" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="SurfaceCardStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.08" Color="#000000" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="11,5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Background" Value="#F8FAFC" />
        </Style>

        <Style x:Key="StatusBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="FilterComboStyle" TargetType="ComboBox">
            <Setter Property="MinWidth" Value="170" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="10,0,0,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="InputPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid x:Name="LoginRoot">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.15*" />
                    <ColumnDefinition Width="0.85*" />
                </Grid.ColumnDefinitions>

                <Border Background="#0B1220">
                    <Grid Margin="58">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <Border Width="50"
                                    Height="50"
                                    Background="#111827"
                                    BorderBrush="#263244"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="iT"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#EF4444"
                                           FontSize="22"
                                           FontWeight="Black" />
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="iioT"
                                           Foreground="White"
                                           FontSize="24"
                                           FontWeight="Black" />
                                <TextBlock Text="AnalictY Console"
                                           Foreground="#F87171"
                                           FontSize="14"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="1" VerticalAlignment="Center" MaxWidth="560">
                            <TextBlock Text="iioT AnalictY Console"
                                       Foreground="White"
                                       FontSize="40"
                                       FontWeight="Black" />
                            <TextBlock Text="Acesso nativo ao AnalictY Server no Windows, com a mesma linguagem visual do web e sem navegador embutido."
                                       Foreground="#CBD5E1"
                                       FontSize="17"
                                       TextWrapping="Wrap"
                                       Margin="0,16,0,0"
                                       Width="520" />

                            <Border Background="#111827"
                                    BorderBrush="#263244"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="18"
                                    Width="520"
                                    HorizontalAlignment="Left"
                                    Margin="0,34,0,0">
                                <StackPanel>
                                    <TextBlock Text="Acesso local e seguro"
                                               Foreground="White"
                                               FontSize="15"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Use o mesmo usuário do AnalictY Server. A sessão fica apenas em memória enquanto o app estiver aberto."
                                               Foreground="#94A3B8"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>

                            <UniformGrid Columns="3" Margin="0,28,0,0" Width="520">
                                <Border Background="#111827" BorderBrush="#243041" BorderThickness="1" CornerRadius="16" Padding="14" Margin="0,0,12,0">
                                    <StackPanel>
                                        <TextBlock Text="Sem WebView" Foreground="#F8FAFC" FontWeight="SemiBold" />
                                        <TextBlock Text="Interface nativa do Windows" Foreground="#94A3B8" FontSize="12" Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#111827" BorderBrush="#243041" BorderThickness="1" CornerRadius="16" Padding="14" Margin="0,0,12,0">
                                    <StackPanel>
                                        <TextBlock Text="Ligado ao servidor" Foreground="#F8FAFC" FontWeight="SemiBold" />
                                        <TextBlock Text="Status e visões reais" Foreground="#94A3B8" FontSize="12" Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#111827" BorderBrush="#243041" BorderThickness="1" CornerRadius="16" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="Sessão em memória" Foreground="#F8FAFC" FontWeight="SemiBold" />
                                        <TextBlock Text="Sem salvar senha" Foreground="#94A3B8" FontSize="12" Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                            <TextBlock Text="Acesso restrito à gestão. Contate o administrador em caso de necessidade."
                                       Foreground="#94A3B8"
                                       FontSize="12" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Background="#F3F5F7">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Margin="32,24,32,0"
                                Background="White"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="22"
                                HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="12" Height="12" CornerRadius="6" Background="#16A34A" Margin="0,0,10,0" />
                                <StackPanel>
                                    <TextBlock Text="AnalictY Server"
                                               Foreground="{StaticResource ContentTextBrush}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Cliente desktop nativo"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="12" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1"
                                Width="440"
                                Background="White"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="22"
                                Padding="34"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Effect="{DynamicResource {x:Static SystemParameters.DropShadowKey}}">
                            <StackPanel>
                                <TextBlock Text="Entrar"
                                           FontSize="30"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ContentTextBrush}" />
                                <TextBlock Text="Use o mesmo acesso do AnalictY Server."
                                           FontSize="14"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Margin="0,8,0,28" />

                                <TextBlock Text="Usuário ou e-mail"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ContentTextBrush}"
                                           Margin="0,0,0,8" />
                                <TextBox Text="{Binding LoginUsername, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputTextBoxStyle}" />

                                <TextBlock Text="Senha"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ContentTextBrush}"
                                           Margin="0,18,0,8" />
                                <PasswordBox x:Name="LoginPasswordBox"
                                             PasswordChanged="LoginPasswordBox_OnPasswordChanged"
                                             Style="{StaticResource InputPasswordBoxStyle}" />

                                <TextBlock Text="{Binding LoginError}"
                                           Foreground="#B91C1C"
                                           TextWrapping="Wrap"
                                           Margin="0,14,0,0" />

                                <Button Content="{Binding LoginButtonText}"
                                        Command="{Binding LoginCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        HorizontalAlignment="Stretch"
                                        Margin="0,22,0,0" />

                                <Border Background="#F8FAFC"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="14"
                                        Margin="0,18,0,0">
                                    <TextBlock Text="Recuperação de senha será disponibilizada em uma próxima etapa."
                                               Foreground="#64748B"
                                               FontSize="12"
                                               TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </Border>

                        <TextBlock Grid.Row="2"
                                   Margin="0,0,0,22"
                                   HorizontalAlignment="Center"
                                   Foreground="#94A3B8"
                                   FontSize="11"
                                   Text="Cliente nativo Windows sem navegador embutido" />
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <Grid x:Name="ShellRoot">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="262" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
                <DockPanel Margin="22,24">
                    <StackPanel DockPanel.Dock="Top">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                            <Border Width="42"
                                    Height="42"
                                    Background="#0F172A"
                                    BorderBrush="#273244"
                                    BorderThickness="1"
                                    VerticalAlignment="Center">
                                <TextBlock Text="iT"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#EF4444"
                                           FontSize="18"
                                           FontWeight="Black" />
                            </Border>
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="iioT"
                                           Foreground="White"
                                           FontSize="23"
                                           FontWeight="Black" />
                                <TextBlock Text="AnalictY Console"
                                           Foreground="#F87171"
                                           FontSize="13" />
                            </StackPanel>
                        </StackPanel>

                        <Border Background="{StaticResource SidebarPanelBrush}"
                                BorderBrush="#2D3946"
                                BorderThickness="1"
                                Padding="14"
                                Margin="0,0,0,20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Usuário"
                                           Foreground="#8EA0B5"
                                           FontSize="12" />
                                <TextBlock Grid.Row="1"
                                           Text="{Binding AuthenticatedUserDisplay}"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Margin="0,3,0,2" />
                                <TextBlock Grid.Row="2"
                                           Text="{Binding AuthenticatedUserRole}"
                                           Foreground="#9CA8B8"
                                           FontSize="12"
                                           Margin="0,0,0,10" />
                                <StackPanel Grid.Row="3" Orientation="Horizontal">
                                    <Ellipse Width="9" Height="9" Margin="0,0,8,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#9CA3AF" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsServerOnline}" Value="True">
                                                        <Setter Property="Fill" Value="#20B486" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="{Binding ServerStatus}"
                                               Foreground="#D7DEE7"
                                               FontSize="12" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <ItemsControl ItemsSource="{Binding NavigationItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Title}"
                                            Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding PageKey}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PageKey}" Value="Exit">
                                                        <Setter Property="Background" Value="#DC2626" />
                                                        <Setter Property="Foreground" Value="White" />
                                                        <Setter Property="Margin" Value="0,18,0,0" />
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <TextBlock DockPanel.Dock="Bottom"
                               Text="Cliente nativo Windows"
                               Foreground="#6E7F92"
                               FontSize="12" />
                </DockPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="78" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="White"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="0,0,0,1">
                    <Grid Margin="30,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentPageTitle}"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ContentTextBrush}" />
                            <TextBlock Text="{Binding CurrentPageSubtitle}"
                                       FontSize="13"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="AnalictY Console"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,18,0" />
                            <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#A3ADB8" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsServerOnline}" Value="True">
                                                <Setter Property="Fill" Value="#20B486" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding ServerStatus}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <Grid Margin="30">
                                                <Grid x:Name="OverviewPage">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="Overview">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <StackPanel>
                                <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,0,0,18" Padding="18,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Resumo operacional"
                                                       Style="{StaticResource SectionTitleStyle}" />
                                            <TextBlock Text="{Binding OverviewDataMessage}"
                                                       Style="{StaticResource SectionSubtitleStyle}"
                                                       Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <ComboBox ItemsSource="{Binding ShiftFilters}"
                                                      SelectedItem="{Binding SelectedShift}"
                                                      Style="{StaticResource FilterComboStyle}" />
                                            <ComboBox ItemsSource="{Binding LineFilters}"
                                                      SelectedItem="{Binding SelectedLine}"
                                                      Style="{StaticResource FilterComboStyle}" />
                                            <Button Content="Atualizar"
                                                    Command="{Binding NavigateCommand}"
                                                    CommandParameter="Overview"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    Margin="14,0,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <ItemsControl ItemsSource="{Binding Kpis}" Margin="0,0,0,8">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="4" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="18"
                                                    Margin="0,0,16,16"
                                                    Padding="18"
                                                    BorderThickness="0">
                                                <Border.Background>
                                                    <Binding Path="AccentBrush" />
                                                </Border.Background>
                                                <Border.Effect>
