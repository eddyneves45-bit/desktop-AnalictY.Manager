<Page x:Class="AnalictY.Console.Views.WeintekBrowserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="760" d:DesignWidth="1280"
      Background="#F3F5F7"
      FontFamily="Segoe UI">
    
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <Grid Margin="0,0,0,24">
                    <StackPanel Orientation="Horizontal">
                        <Button Width="40" Height="40" Margin="0,0,16,0"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Click="BackButton_Click">
                            <Path Data="M19 12H5M12 19l-7-7 7-7" 
                                  Stroke="#6B7280" StrokeThickness="2" 
                                  Fill="Transparent" 
                                  Width="20" Height="20" Stretch="Uniform"/>
                        </Button>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Weintek HTTP" FontSize="28" FontWeight="Bold" Foreground="#111827"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="24" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="Configuração Weintek HTTP" FontSize="18" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,16"/>
                        <TextBlock Text="Gateway FHDX/cMT e browser de tags" FontSize="14" Foreground="#6B7280" Margin="0,0,0,16"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Nome:" Foreground="#374151" Margin="0,0,0,8"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                     BorderBrush="#D1D5DB" BorderThickness="1" Padding="8"
                                     Text="Weintek Gateway"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="URL do Gateway:" Foreground="#374151" Margin="0,0,0,8"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                     BorderBrush="#D1D5DB" BorderThickness="1" Padding="8"
                                     Text="http://192.168.1.100"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Porta:" Foreground="#374151" Margin="0,0,0,8"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                     BorderBrush="#D1D5DB" BorderThickness="1" Padding="8"
                                     Text="80"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Usuário:" Foreground="#374151" Margin="0,0,0,8"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                     BorderBrush="#D1D5DB" BorderThickness="1" Padding="8"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Senha:" Foreground="#374151" Margin="0,0,0,8"/>
                            <PasswordBox Grid.Row="4" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                         BorderBrush="#D1D5DB" BorderThickness="1" Padding="8"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Conexão Ativa:" Foreground="#374151" Margin="0,0,0,8"/>
                            <CheckBox Grid.Row="5" Grid.Column="1" Margin="0,0,0,16" IsChecked="True"
                                      Content="Habilitar conexão"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Content="Limpar" 
                                    Background="#E5E7EB" Foreground="#374151"
                                    BorderThickness="0" Padding="16,8" Margin="0,0,8,0"
                                    Cursor="Hand"/>
                            <Button Content="Testar Conexão" 
                                    Background="#10B981" Foreground="White"
                                    BorderThickness="0" Padding="16,8" Margin="0,0,8,0"
                                    Cursor="Hand"/>
                            <Button Content="Salvar" 
                                    Background="#DC2626" Foreground="White"
                                    BorderThickness="0" Padding="16,8"
                                    Cursor="Hand"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
