<Page x:Class="AnalictY.Console.Views.LocalServerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="760" d:DesignWidth="1280"
      Background="#F3F5F7"
      FontFamily="Segoe UI">
    
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <Grid Margin="0,0,0,24">
                    <StackPanel Orientation="Horizontal">
                        <Button Width="40" Height="40" Margin="0,0,16,0"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Click="BackButton_Click">
                            <Path Data="M19 12H5M12 19l-7-7 7-7" 
                                  Stroke="#6B7280" StrokeThickness="2" 
                                  Fill="Transparent" 
                                  Width="20" Height="20" Stretch="Uniform"/>
                        </Button>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Servidor local" FontSize="28" FontWeight="Bold" Foreground="#111827"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="24" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="Configuração de Servidor Local" FontSize="18" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,16"/>
                        <TextBlock Text="Acesso por localhost ou IP fixo" FontSize="14" Foreground="#6B7280" Margin="0,0,0,16"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Modo de Rede:" Foreground="#374151" Margin="0,0,0,8"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                      BorderBrush="#D1D5DB" BorderThickness="1" Padding="8">
                                <ComboBoxItem Content="Localhost (padrão)"/>
                                <ComboBoxItem Content="IP Fixo"/>
                            </ComboBox>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="IP Fixo:" Foreground="#374151" Margin="0,0,0,8"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                     BorderBrush="#D1D5DB" BorderThickness="1" Padding="8"
                                     Text="192.168.55.147"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Porta Backend:" Foreground="#374151" Margin="0,0,0,8"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                     BorderBrush="#D1D5DB" BorderThickness="1" Padding="8"
                                     Text="5000" IsReadOnly="True"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Porta Frontend:" Foreground="#374151" Margin="0,0,0,8"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Height="36" Margin="0,0,0,16"
                                     BorderBrush="#D1D5DB" BorderThickness="1" Padding="8"
                                     Text="3000" IsReadOnly="True"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Content="Salvar Configuração" 
                                    Background="#0891B2" Foreground="White"
                                    BorderThickness="0" Padding="16,8"
                                    Cursor="Hand"/>
                        </StackPanel>

                        <Border Background="#F0F9FF" CornerRadius="8" Padding="16" Margin="0,16,0,0">
                            <TextBlock Text="URL de Acesso: http://localhost:3000/config" Foreground="#0369A1" FontSize="14" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
