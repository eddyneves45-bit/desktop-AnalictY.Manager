<Page x:Class="AnalictY.Console.Views.ConfigDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="760" d:DesignWidth="1280"
      Background="#F3F5F7"
      FontFamily="Segoe UI">
    
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <!-- Header -->
                <Grid Margin="0,0,0,24">
                    <StackPanel Orientation="Horizontal">
                        <Button Width="40" Height="40" Margin="0,0,16,0"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Click="BackButton_Click">
                            <Path Data="M19 12H5M12 19l-7-7 7-7" 
                                  Stroke="#6B7280" StrokeThickness="2" 
                                  Fill="Transparent" 
                                  Width="20" Height="20" Stretch="Uniform"/>
                        </Button>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="TitleText" 
                                       Text="Configuração" 
                                       FontSize="28" FontWeight="Bold" 
                                       Foreground="#111827"/>
                            <TextBlock x:Name="DescriptionText" 
                                       Text="Detalhes da configuração" 
                                       FontSize="14" 
                                       Foreground="#6B7280" Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Content Placeholder -->
                <Border Background="White" 
                        BorderBrush="#E5E7EB" 
                        BorderThickness="1" 
                        CornerRadius="12" 
                        Padding="24"
                        MinHeight="400">
                    <StackPanel>
                        <TextBlock Text="Configuração em desenvolvimento" 
                                   FontSize="18" 
                                   FontWeight="SemiBold" 
                                   Foreground="#111827"
                                   HorizontalAlignment="Center"
                                   Margin="0,40,0,16"/>
                        <TextBlock Text="Esta página será implementada com os campos específicos desta configuração." 
                                   FontSize="14" 
                                   Foreground="#6B7280"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
